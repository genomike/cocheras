@using Radzen
@using Radzen.Blazor
@using Cochera.Application.DTOs
@using Cochera.Web.Services
@inject UsuarioActualService UsuarioActualService
@inject NavigationManager NavigationManager

<div style="padding: 1rem; background: var(--rz-panel-menu-background-color); border-top: 1px solid var(--rz-border-color);">
    <RadzenText TextStyle="TextStyle.Caption" Style="margin-bottom: 0.5rem; color: var(--rz-text-secondary-color);">
        Cambiar Usuario:
    </RadzenText>
    <RadzenDropDown TValue="int" 
        @bind-Value="@usuarioSeleccionadoId" 
        Data="@usuarios" 
        TextProperty="Nombre" 
        ValueProperty="Id" 
        Placeholder="Seleccione usuario"
        Style="width: 100%;" 
        Change="@(EventCallback.Factory.Create<object>(this, OnUsuarioChanged))" />
</div>

@code {
    private List<UsuarioDto> usuarios = new();
    private int usuarioSeleccionadoId;

    protected override async Task OnInitializedAsync()
    {
        usuarios = (await UsuarioActualService.GetTodosUsuariosAsync()).ToList();
        
        if (UsuarioActualService.EstaLogueado)
        {
            usuarioSeleccionadoId = UsuarioActualService.UsuarioActual!.Id;
        }
    }

    private async Task OnUsuarioChanged(object value)
    {
        if (value is int id && id > 0)
        {
            usuarioSeleccionadoId = id;
            await UsuarioActualService.CambiarUsuarioAsync(id);
            
            // Navegar a la página principal del rol
            if (UsuarioActualService.EsAdmin)
            {
                NavigationManager.NavigateTo("/admin/dashboard", forceLoad: true);
            }
            else
            {
                NavigationManager.NavigateTo("/usuario/disponibilidad", forceLoad: true);
            }
        }
    }
}
