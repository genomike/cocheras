@using Cochera.Application.DTOs
@using Cochera.Web.Services
@inject UsuarioActualService UsuarioActualService
@inject NavigationManager NavigationManager
@implements IDisposable

<div class="user-selector">
    <label class="user-selector-label">
        👤 Cambiar Usuario:
    </label>
    <select @bind="usuarioSeleccionadoId" @bind:after="OnUsuarioChanged" class="user-selector-dropdown">
        <option value="0">-- Seleccione usuario --</option>
        @foreach (var usuario in usuarios)
        {
            <option value="@usuario.Id">
                @(usuario.EsAdmin ? "👑 " : "")@usuario.Nombre
            </option>
        }
    </select>
</div>

<style>
    .user-selector {
        padding: 0.75rem;
        border-top: 1px solid rgba(255,255,255,0.1);
        background: rgba(0,0,0,0.1);
    }
    .user-selector-label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.75rem;
        color: rgba(255,255,255,0.7);
    }
    .user-selector-dropdown {
        width: 100%;
        padding: 0.5rem;
        border-radius: 4px;
        border: 1px solid rgba(255,255,255,0.3);
        background: #fff;
        cursor: pointer;
        font-size: 0.875rem;
    }
    @@media (max-width: 768px) {
        .user-selector {
            padding: 0.5rem;
        }
        .user-selector-label {
            font-size: 0.7rem;
        }
        .user-selector-dropdown {
            padding: 0.4rem;
            font-size: 0.8rem;
        }
    }
</style>

@code {
    private List<UsuarioDto> usuarios = new();
    private int usuarioSeleccionadoId;

    protected override async Task OnInitializedAsync()
    {
        usuarios = (await UsuarioActualService.GetTodosUsuariosAsync()).ToList();
        SyncUsuarioSeleccionado();
        
        // Suscribirse a cambios de usuario
        UsuarioActualService.OnUsuarioCambiado += OnUsuarioCambiadoExterno;
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Esperar a que UsuarioActualService se inicialice
            await Task.Delay(100);
            SyncUsuarioSeleccionado();
            StateHasChanged();
        }
    }
    
    private void SyncUsuarioSeleccionado()
    {
        if (UsuarioActualService.EstaLogueado && UsuarioActualService.UsuarioActual != null)
        {
            usuarioSeleccionadoId = UsuarioActualService.UsuarioActual.Id;
        }
        else
        {
            usuarioSeleccionadoId = 0;
        }
    }
    
    private void OnUsuarioCambiadoExterno()
    {
        SyncUsuarioSeleccionado();
        InvokeAsync(StateHasChanged);
    }

    private async Task OnUsuarioChanged()
    {
        if (usuarioSeleccionadoId > 0)
        {
            await UsuarioActualService.CambiarUsuarioAsync(usuarioSeleccionadoId);
            
            // Navegar solo si cambiamos de tipo de usuario (admin <-> usuario)
            var destino = UsuarioActualService.EsAdmin ? "/admin/dashboard" : "/usuario/disponibilidad";
            NavigationManager.NavigateTo(destino);
        }
    }
    
    public void Dispose()
    {
        UsuarioActualService.OnUsuarioCambiado -= OnUsuarioCambiadoExterno;
    }
}


