@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Radzen
@using Radzen.Blazor
@using Cochera.Application.DTOs
@using Cochera.Web.Services
@inject UsuarioActualService UsuarioActualService
@inject NavigationManager NavigationManager

<RadzenLayout Style="--rz-sidebar-width: 220px;">
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0" class="header-content">
            <RadzenSidebarToggle Click="@(() => sidebarExpanded = !sidebarExpanded)" />
            <RadzenLabel Text="Sistema de Cochera" class="app-title" />
            <div style="flex-grow: 1;"></div>
            <AuthorizeView>
                <Authorized>
                    @if (UsuarioActualService.EstaLogueado)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem" class="user-info">
                            <span class="icon-text" Style="font-size: 1rem;" >[ROL]</span>
                            <span class="user-name">@UsuarioActualService.UsuarioActual?.Nombre</span>
                            @if (UsuarioActualService.EsAdmin)
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="Admin" class="admin-badge" />
                            }
                            <RadzenButton Text="Salir" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light" Click="CerrarSesion" />
                        </RadzenStack>
                    }
                </Authorized>
            </AuthorizeView>
        </RadzenStack>
    </RadzenHeader>
    <RadzenSidebar @bind-Expanded="@sidebarExpanded" class="app-sidebar">
        <RadzenPanelMenu Style="flex: 1;">
            @if (!UsuarioActualService.EstaLogueado)
            {
                <RadzenPanelMenuItem Text="Iniciar sesión" Path="/login" />
            }
            else if (UsuarioActualService.EsAdmin)
            {
                <!-- Menú de Administrador -->
                <RadzenPanelMenuItem Text="Dashboard" Path="/admin/dashboard" />
                <RadzenPanelMenuItem Text="Gestión Entrada/Salida" Path="/admin/gestion-entrada" />
                <RadzenPanelMenuItem Text="Sesiones Activas" Path="/admin/sesiones" />
                <RadzenPanelMenuItem Text="Historial Sesiones" Path="/admin/historial" />
                <RadzenPanelMenuItem Text="Eventos Sensores" Path="/admin/eventos" />
                <RadzenPanelMenuItem Text="Gestión" Expanded="true">
                    <RadzenPanelMenuItem Text="Tarifas" Path="/admin/tarifas" />
                    <RadzenPanelMenuItem Text="Cajones" Path="/admin/cajones" />
                </RadzenPanelMenuItem>
                <RadzenPanelMenuItem Text="Reportes" Path="/admin/reportes" />
            }
            else
            {
                <!-- Menú de Usuario Normal -->
                <RadzenPanelMenuItem Text="Mi Estacionamiento" Path="/usuario/estacionamiento" />
                <RadzenPanelMenuItem Text="Mis Pagos" Path="/usuario/pagos" />
                <RadzenPanelMenuItem Text="Mi Historial" Path="/usuario/historial" />
            }
        </RadzenPanelMenu>
    </RadzenSidebar>
    <RadzenBody class="app-body">
        <div class="page-content">
            @Body
        </div>
    </RadzenBody>
</RadzenLayout>

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />

<style>
    /* Estilos responsive para mobile */
    .header-content {
        width: 100%;
    }
    .app-title {
        font-size: 1.25rem;
        font-weight: bold;
        margin-left: 8px;
        white-space: nowrap;
    }
    .user-info {
        margin-right: 0.5rem;
    }
    .user-name {
        color: white;
        font-size: 0.875rem;
    }
    .admin-badge {
        margin-left: 4px;
        font-size: 0.7rem !important;
    }
    .app-sidebar {
        display: flex;
        flex-direction: column;
    }
    .app-body {
        padding-bottom: 60px;
    }
    .page-content {
        padding: 1rem;
    }
    
    /* Mobile styles */
    @@media (max-width: 768px) {
        .app-title {
            font-size: 1rem;
            margin-left: 4px;
        }
        .user-name {
            display: none;
        }
        .user-info {
            margin-right: 0.25rem;
        }
        .admin-badge {
            font-size: 0.6rem !important;
            padding: 2px 4px !important;
        }
        .page-content {
            padding: 0.5rem;
        }
        .app-body {
            padding-bottom: 40px;
        }
        :root {
            --rz-sidebar-width: 200px;
        }
    }
</style>

@code {
    bool sidebarExpanded = true;
    private bool _initialized = false;
    private string? _lastUrl;

    protected override void OnInitialized()
    {
        UsuarioActualService.OnUsuarioCambiado += OnUsuarioCambiadoHandler;
        // Guardar URL actual para restaurar después de refresh
        _lastUrl = NavigationManager.Uri;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            _initialized = true;
            await UsuarioActualService.InitializeAsync();
            
            // Si hay usuario logueado después de inicializar, mantener página actual
            // No redirigir automáticamente
            StateHasChanged();
        }
    }

    private void OnUsuarioCambiadoHandler()
    {
        InvokeAsync(StateHasChanged);
    }

    private void CerrarSesion()
    {
        NavigationManager.NavigateTo("/logout", forceLoad: true);
    }

    public void Dispose()
    {
        UsuarioActualService.OnUsuarioCambiado -= OnUsuarioCambiadoHandler;
    }
}


