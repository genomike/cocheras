@using Cochera.Application.DTOs
@using Cochera.Domain.Enums
@using Radzen
@using Radzen.Blazor

<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.Body1">
        <strong>Cajón:</strong> @Sesion.CajonNumero
    </RadzenText>
    <RadzenText TextStyle="TextStyle.Body1">
        <strong>Entrada:</strong> @Sesion.HoraEntrada.ToString("dd/MM/yyyy HH:mm:ss")
    </RadzenText>
    <RadzenText TextStyle="TextStyle.Body1">
        <strong>Tiempo:</strong> @Sesion.MinutosEstacionado minutos
    </RadzenText>
    <RadzenText TextStyle="TextStyle.Body1">
        <strong>Tarifa:</strong> S/ @Sesion.TarifaPorMinuto.ToString("N2") /min
    </RadzenText>
    <RadzenText TextStyle="TextStyle.H5" Style="color: var(--rz-success);">
        <strong>Total a Pagar:</strong> S/ @Sesion.MontoTotal.ToString("N2")
    </RadzenText>

    <RadzenFormField Text="Método de Pago" Variant="Variant.Outlined" Style="width: 100%;">
        <RadzenDropDown @bind-Value="@metodoPago" Data="@metodosPago" Style="width: 100%;" />
    </RadzenFormField>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" JustifyContent="JustifyContent.End">
        <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close())" />
        <RadzenButton Text="Confirmar Pago" ButtonStyle="ButtonStyle.Success" Icon="payment" 
            Click="@(() => DialogService.Close(metodoPago))" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public SesionEstacionamientoDto Sesion { get; set; } = null!;
    [Inject] private DialogService DialogService { get; set; } = null!;

    private MetodoPago metodoPago = MetodoPago.Efectivo;
    private List<MetodoPago> metodosPago = Enum.GetValues<MetodoPago>().ToList();
}
