</style>

@code {
    private List<CajonDto> cajones = new();
    private SesionEstacionamientoDto? sesionActiva;
    private SesionEstacionamientoDto? sesionPendientePago;
    private SesionEstacionamientoDto? sesionFinalizada;
    private TarifaDto? tarifaActual;
    private EstadoCocheraDto? estadoCochera;
    private bool procesandoPago;
    private bool mostrarMensajeDespedida;
    private HubConnection? hubConnection;
    private System.Timers.Timer? actualizadorMonto;

    protected override async Task OnInitializedAsync()
    {
        if (!UsuarioActualService.EstaLogueado || UsuarioActualService.EsAdmin)
        {
            Navigation.NavigateTo("/");
            return;
        }
        
        await LoadData();
        await SetupSignalR();
        SetupActualizadorMonto();
    }

    private async Task LoadData()
    {
        cajones = (await CajonService.GetAllAsync()).ToList();
        tarifaActual = await TarifaService.GetTarifaActivaAsync();
        estadoCochera = await EstadoCocheraService.GetEstadoActualAsync();
        
        // Sincronizar cajones con el estado real de los sensores
        if (estadoCochera != null && cajones.Count >= 2)
        {
            var cajon1 = cajones.FirstOrDefault(c => c.Numero == 1);
            var cajon2 = cajones.FirstOrDefault(c => c.Numero == 2);
            if (cajon1 != null) cajon1.Estado = estadoCochera.Cajon1Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
            if (cajon2 != null) cajon2.Estado = estadoCochera.Cajon2Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
        }
        
        if (UsuarioActualService.UsuarioId.HasValue)
        {
            sesionActiva = await SesionService.GetSesionActivaByUsuarioAsync(UsuarioActualService.UsuarioId.Value);
            sesionPendientePago = await SesionService.GetSesionPendientePagoByUsuarioAsync(UsuarioActualService.UsuarioId.Value);
        }
    }

    private async Task SetupSignalR()
    {
        if (!UsuarioActualService.UsuarioId.HasValue) return;

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/cocherahub"))
            .WithAutomaticReconnect()
            .Build();

        // Nueva sesión creada para este usuario - ACTUALIZAR VISTA AUTOMÁTICAMENTE
        hubConnection.On<SesionEstacionamientoDto>("MiNuevaSesion", async (sesion) =>
        {
            // Recargar todos los datos para asegurar que la UI cambie de disponibilidad a sesión activa
            await LoadData();
            sesionActiva = sesion;
            sesionPendientePago = null;
            mostrarMensajeDespedida = false;
            await InvokeAsync(StateHasChanged);
            
            NotificationService.Notify(NotificationSeverity.Success, "VEHICULO ¡Sesión Iniciada!", 
                $"Bienvenido! Te asignamos el Cajón {sesion.CajonNumero}");
        });

        // Admin solicita cierre de sesión
        hubConnection.On<SesionEstacionamientoDto>("SolicitudCierreSesion", async (sesion) =>
        {
            sesionActiva = null;
            sesionPendientePago = sesion;
            await InvokeAsync(StateHasChanged);
            NotificationService.Notify(NotificationSeverity.Warning, "💰 Hora de pagar", 
                $"Por favor, procede al pago de S/ {sesion.MontoTotal:N2}");
        });

        // Sesión cerrada
        hubConnection.On<SesionEstacionamientoDto>("SesionCerrada", async (sesion) =>
        {
            sesionActiva = null;
            sesionPendientePago = null;
            sesionFinalizada = sesion;
            mostrarMensajeDespedida = true;
            await InvokeAsync(StateHasChanged);
            NotificationService.Notify(NotificationSeverity.Success, "OK ¡Hasta pronto!", 
                "Tu sesión ha sido cerrada. ¡Gracias por visitarnos!");
            
            // Ocultar mensaje de despedida después de 30 segundos
            _ = Task.Delay(30000).ContinueWith(async _ =>
            {
                mostrarMensajeDespedida = false;
                sesionFinalizada = null;
                await InvokeAsync(StateHasChanged);
            });
        });

        // Actualización de monto en tiempo real
        hubConnection.On<SesionEstacionamientoDto>("ActualizarMontoSesion", async (sesion) =>
        {
            if (sesionActiva != null && sesionActiva.Id == sesion.Id)
            {
                sesionActiva = sesion;
                await InvokeAsync(StateHasChanged);
            }
        });

        // Actualizar cajones en tiempo real
        hubConnection.On<EstadoCocheraDto>("ActualizarCajones", async (estado) =>
        {
            estadoCochera = estado;
            if (cajones.Count >= 2)
            {
                var cajon1 = cajones.FirstOrDefault(c => c.Numero == 1);
                var cajon2 = cajones.FirstOrDefault(c => c.Numero == 2);
                if (cajon1 != null) cajon1.Estado = estado.Cajon1Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
                if (cajon2 != null) cajon2.Estado = estado.Cajon2Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
            }
            
            // VERIFICAR SI EL USUARIO TIENE SESIÓN ACTIVA - crucial para cambiar de disponibilidad a sesión activa
            if (UsuarioActualService.UsuarioId.HasValue && sesionActiva == null)
            {
                var sesion = await SesionService.GetSesionActivaByUsuarioAsync(UsuarioActualService.UsuarioId.Value);
                if (sesion != null)
                {
                    sesionActiva = sesion;
                }
            }
            
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<EstadoCocheraDto>("RecibirEstado", async (estado) =>
        {
            estadoCochera = estado;
            if (cajones.Count >= 2)
            {
                var cajon1 = cajones.FirstOrDefault(c => c.Numero == 1);
                var cajon2 = cajones.FirstOrDefault(c => c.Numero == 2);
                if (cajon1 != null) cajon1.Estado = estado.Cajon1Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
                if (cajon2 != null) cajon2.Estado = estado.Cajon2Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
            }
            
            // VERIFICAR SI EL USUARIO TIENE SESIÓN ACTIVA - crucial para cambiar de disponibilidad a sesión activa
            if (UsuarioActualService.UsuarioId.HasValue && sesionActiva == null)
            {
                var sesion = await SesionService.GetSesionActivaByUsuarioAsync(UsuarioActualService.UsuarioId.Value);
                if (sesion != null)
                {
                    sesionActiva = sesion;
                }
            }
            
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }

    private void SetupActualizadorMonto()
    {
        actualizadorMonto = new System.Timers.Timer(30000); // Cada 30 segundos
        actualizadorMonto.Elapsed += async (sender, e) =>
        {
            if (sesionActiva != null && UsuarioActualService.UsuarioId.HasValue)
            {
                // Refrescar sesión activa para actualizar monto
                sesionActiva = await SesionService.GetSesionActivaByUsuarioAsync(UsuarioActualService.UsuarioId.Value);
                await InvokeAsync(StateHasChanged);
            }
        };
        actualizadorMonto.Start();
    }

    private string GetCajonClass(CajonDto cajon)
    {
        var baseClass = "rz-shadow-3 cajon-card ";
        return cajon.Estado == EstadoCajon.Libre 
            ? baseClass + "cajon-libre" 
            : baseClass + "cajon-ocupado";
    }

    private string GetCajonCardClass(CajonDto cajon)
    {
        return cajon.Estado == EstadoCajon.Libre 
            ? "cajon-card cajon-libre" 
            : "cajon-card cajon-ocupado";
    }

    private async Task ConfirmarPago(MetodoPago metodoPago)
    {
        if (sesionPendientePago == null || !UsuarioActualService.UsuarioId.HasValue) return;

        var confirmacion = await DialogService.Confirm(
            $"¿Confirmar pago de S/ {sesionPendientePago.MontoTotal:N2} con {(metodoPago == MetodoPago.Efectivo ? "Efectivo" : "Tarjeta")}?",
            "Confirmar Pago",
            new ConfirmOptions { OkButtonText = "Confirmar Pago", CancelButtonText = "Cancelar" });

        if (confirmacion == true)
        {
            procesandoPago = true;
            try
            {
                var confirmacionPago = new ConfirmacionPagoDto
                {
                    SesionId = sesionPendientePago.Id,
                    UsuarioId = UsuarioActualService.UsuarioId.Value,
                    MetodoPago = metodoPago
                };

                var sesionFinal = await SesionService.ConfirmarPagoUsuarioAsync(confirmacionPago);
                
                // Notificar al admin via SignalR
                await SesionNotificationService.NotificarPagoConfirmadoAsync(sesionFinal);
                
                // La sesión ya está cerrada automáticamente, mostrar mensaje de despedida
                sesionPendientePago = null;
                sesionActiva = null;
                sesionFinalizada = sesionFinal;
                mostrarMensajeDespedida = true;
                
                NotificationService.Notify(NotificationSeverity.Success, "OK ¡Pago exitoso!", 
                    "Tu pago ha sido procesado. ¡Gracias por visitarnos!");
                
                // Ocultar mensaje de despedida después de 30 segundos
                _ = Task.Delay(30000).ContinueWith(async _ =>
                {
                    mostrarMensajeDespedida = false;
                    sesionFinalizada = null;
                    await InvokeAsync(StateHasChanged);
                });
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
            }
            finally
            {
                procesandoPago = false;
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        actualizadorMonto?.Stop();
        actualizadorMonto?.Dispose();
        
        if (hubConnection != null)
        {
            if (UsuarioActualService.UsuarioId.HasValue)
            {
                await hubConnection.InvokeAsync("SalirDeGrupoUsuario", UsuarioActualService.UsuarioId.Value);
            }
            await hubConnection.DisposeAsync();
        }
    }
}


