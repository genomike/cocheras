@page "/usuario/estacionamiento"
@using Cochera.Application.DTOs
@using Cochera.Application.Interfaces
@using Cochera.Web.Services
@using Cochera.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@using Radzen
@using Radzen.Blazor
@inject ICajonService CajonService
@inject ISesionService SesionService
@inject ITarifaService TarifaService
@inject ISesionNotificationService SesionNotificationService
@inject UsuarioActualService UsuarioActualService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject DialogService DialogService
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Mi Estacionamiento - Cochera</PageTitle>

@if (!UsuarioActualService.EstaLogueado || UsuarioActualService.EsAdmin)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger">Acceso denegado.</RadzenAlert>
}
else
{
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-mb-4">
        <RadzenIcon Icon="directions_car" /> Mi Estacionamiento
    </RadzenText>

    @if (sesionPendientePago != null)
    {
        <!-- ESTADO: Pendiente de Pago -->
        <RadzenCard class="rz-shadow-4 sesion-pago-pendiente rz-mb-4">
            <div style="text-align: center;">
                <RadzenIcon Icon="payment" Style="font-size: 4rem; color: var(--rz-warning);" />
                <RadzenText TextStyle="TextStyle.H4" class="rz-mt-2">
                    ¡Es hora de pagar!
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-4">
                    El administrador ha solicitado el cierre de tu sesión.
                </RadzenText>
            </div>

            <RadzenRow Gap="2rem" JustifyContent="JustifyContent.Center">
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenCard class="info-resumen">
                        <RadzenStack Gap="1rem">
                            <RadzenRow>
                                <RadzenColumn Size="6"><strong>Cajón:</strong></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">@sesionPendientePago.CajonNumero</RadzenColumn>
                            </RadzenRow>
                            <RadzenRow>
                                <RadzenColumn Size="6"><strong>Hora entrada:</strong></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">@sesionPendientePago.HoraEntrada.ToString("HH:mm:ss")</RadzenColumn>
                            </RadzenRow>
                            <RadzenRow>
                                <RadzenColumn Size="6"><strong>Hora salida:</strong></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">@(sesionPendientePago.HoraSalida?.ToString("HH:mm:ss") ?? "-")</RadzenColumn>
                            </RadzenRow>
                            <RadzenRow>
                                <RadzenColumn Size="6"><strong>Tiempo total:</strong></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">@sesionPendientePago.TiempoFormateado</RadzenColumn>
                            </RadzenRow>
                            <RadzenRow>
                                <RadzenColumn Size="6"><strong>Tarifa por minuto:</strong></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">S/ @sesionPendientePago.TarifaPorMinuto.ToString("N2")</RadzenColumn>
                            </RadzenRow>
                            <hr />
                            <RadzenRow>
                                <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.H5">TOTAL A PAGAR:</RadzenText></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">
                                    <RadzenText TextStyle="TextStyle.H4" Style="color: var(--rz-success);">
                                        S/ @sesionPendientePago.MontoTotal.ToString("N2")
                                    </RadzenText>
                                </RadzenColumn>
                            </RadzenRow>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>

            <div style="text-align: center; margin-top: 2rem;">
                @if (sesionPendientePago.TienePago)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success" class="rz-mb-4">
                        <RadzenIcon Icon="check_circle" /> ¡Pago confirmado! Esperando que el administrador cierre tu sesión...
                    </RadzenAlert>
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-4">Selecciona tu método de pago:</RadzenText>
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" JustifyContent="JustifyContent.Center">
                        <RadzenButton Text="Pagar con Efectivo" Icon="payments" Size="ButtonSize.Large"
                            ButtonStyle="ButtonStyle.Success" Click="@(() => ConfirmarPago(MetodoPago.Efectivo))" 
                            IsBusy="@procesandoPago" />
                        <RadzenButton Text="Pagar con Tarjeta" Icon="credit_card" Size="ButtonSize.Large"
                            ButtonStyle="ButtonStyle.Primary" Click="@(() => ConfirmarPago(MetodoPago.Tarjeta))" 
                            IsBusy="@procesandoPago" />
                    </RadzenStack>
                }
            </div>
        </RadzenCard>
    }
    else if (sesionActiva != null)
    {
        <!-- ESTADO: Sesión activa -->
        <RadzenCard class="rz-shadow-4 sesion-activa rz-mb-4">
            <RadzenText TextStyle="TextStyle.H4" class="rz-mb-4">
                <RadzenIcon Icon="local_parking" /> Tienes una sesión activa
            </RadzenText>
            
            <RadzenRow Gap="2rem">
                <RadzenColumn Size="12" SizeMD="6">
                    <div style="text-align: center; font-size: 8rem; margin-bottom: 1rem;">🚗</div>
                    <RadzenText TextStyle="TextStyle.H3" Style="text-align: center;">Cajón @sesionActiva.CajonNumero</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenStack Gap="1rem">
                        <RadzenCard class="info-card">
                            <RadzenIcon Icon="schedule" />
                            <div>
                                <RadzenText TextStyle="TextStyle.Caption">Hora de entrada</RadzenText>
                                <RadzenText TextStyle="TextStyle.H5">@sesionActiva.HoraEntrada.ToString("HH:mm:ss")</RadzenText>
                            </div>
                        </RadzenCard>
                        <RadzenCard class="info-card">
                            <RadzenIcon Icon="timer" />
                            <div>
                                <RadzenText TextStyle="TextStyle.Caption">Tiempo estacionado</RadzenText>
                                <RadzenText TextStyle="TextStyle.H5">@sesionActiva.TiempoFormateado</RadzenText>
                            </div>
                        </RadzenCard>
                        <RadzenCard class="info-card">
                            <RadzenIcon Icon="attach_money" />
                            <div>
                                <RadzenText TextStyle="TextStyle.Caption">Tarifa por minuto</RadzenText>
                                <RadzenText TextStyle="TextStyle.H5">S/ @sesionActiva.TarifaPorMinuto.ToString("N2")</RadzenText>
                            </div>
                        </RadzenCard>
                        <RadzenCard class="info-card monto-total">
                            <RadzenIcon Icon="payments" />
                            <div>
                                <RadzenText TextStyle="TextStyle.Caption">Monto acumulado</RadzenText>
                                <RadzenText TextStyle="TextStyle.H3">S/ @sesionActiva.MontoTotal.ToString("N2")</RadzenText>
                            </div>
                        </RadzenCard>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
            
            <!-- Mensaje informativo: El admin debe solicitar el cierre -->
            <RadzenAlert AlertStyle="AlertStyle.Info" class="rz-mt-4">
                <RadzenIcon Icon="info" /> Cuando estés listo para salir, el administrador procesará tu salida y te solicitará el pago.
            </RadzenAlert>
        </RadzenCard>
    }
    else if (sesionFinalizada != null && mostrarMensajeDespedida)
    {
        <!-- ESTADO: Sesión finalizada - Mensaje de despedida -->
        <RadzenCard class="rz-shadow-4 sesion-finalizada rz-mb-4">
            <div style="text-align: center;">
                <div style="font-size: 6rem; margin-bottom: 1rem;">👋</div>
                <RadzenText TextStyle="TextStyle.H3" class="rz-mb-2">¡Gracias por visitarnos!</RadzenText>
                <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-4">Tu sesión ha sido cerrada exitosamente.</RadzenText>
                
                <RadzenCard class="info-resumen" Style="max-width: 400px; margin: 0 auto;">
                    <RadzenStack Gap="0.5rem">
                        <RadzenRow>
                            <RadzenColumn Size="6">Cajón:</RadzenColumn>
                            <RadzenColumn Size="6" Style="text-align: right;">@sesionFinalizada.CajonNumero</RadzenColumn>
                        </RadzenRow>
                        <RadzenRow>
                            <RadzenColumn Size="6">Duración:</RadzenColumn>
                            <RadzenColumn Size="6" Style="text-align: right;">@sesionFinalizada.TiempoFormateado</RadzenColumn>
                        </RadzenRow>
                        <RadzenRow>
                            <RadzenColumn Size="6"><strong>Total pagado:</strong></RadzenColumn>
                            <RadzenColumn Size="6" Style="text-align: right;"><strong>S/ @sesionFinalizada.MontoTotal.ToString("N2")</strong></RadzenColumn>
                        </RadzenRow>
                    </RadzenStack>
                </RadzenCard>
                
                <RadzenButton Text="Ver mi historial" Icon="history" ButtonStyle="ButtonStyle.Primary" 
                    Style="margin-top: 2rem;" Click="@(() => Navigation.NavigateTo("/usuario/historial"))" />
            </div>
        </RadzenCard>
    }
    else
    {
        <!-- ESTADO: Sin sesión activa -->
        <RadzenAlert AlertStyle="AlertStyle.Info" class="rz-mb-4">
            No tienes ninguna sesión de estacionamiento activa. El administrador registrará tu entrada cuando llegues.
        </RadzenAlert>

        <RadzenCard class="rz-shadow-3 rz-mb-4">
            <RadzenText TextStyle="TextStyle.H5" class="rz-mb-2">
                <RadzenIcon Icon="info" /> Información de Tarifa
            </RadzenText>
            @if (tarifaActual != null)
            {
                <RadzenText>Tarifa actual: <strong>S/ @tarifaActual.PrecioPorMinuto.ToString("N2") por minuto</strong></RadzenText>
                <RadzenText TextStyle="TextStyle.Caption" class="rz-mt-2">
                    * La fracción de minuto se cobra como minuto completo.
                </RadzenText>
            }
        </RadzenCard>

        <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">Estado de los cajones:</RadzenText>

        <RadzenRow Gap="2rem" JustifyContent="JustifyContent.Center">
            @foreach (var cajon in cajones)
            {
                <RadzenColumn Size="12" SizeMD="5">
                    <RadzenCard class="@GetCajonClass(cajon)" Style="text-align: center; padding: 2rem;">
                        <div style="font-size: 5rem; margin-bottom: 1rem;">
                            @if (cajon.Estado == EstadoCajon.Ocupado)
                            {
                                <span>🚗</span>
                            }
                            else
                            {
                                <span>🅿️</span>
                            }
                        </div>
                        <RadzenText TextStyle="TextStyle.H4">Cajón @cajon.Numero</RadzenText>
                        <RadzenText TextStyle="TextStyle.Body1" class="rz-mt-2">
                            @if (cajon.Estado == EstadoCajon.Libre)
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="DISPONIBLE" />
                            }
                            else
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="OCUPADO" />
                            }
                        </RadzenText>
                    </RadzenCard>
                </RadzenColumn>
            }
        </RadzenRow>
    }
}

<style>
    /* Mobile-first design */
    .page-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }
    .page-icon { font-size: 1.5rem; color: var(--rz-primary); }
    .page-title { font-size: 1.25rem; font-weight: 600; }
    
    .sesion-activa {
        background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
        border: 2px solid #ff9800;
        padding: 1rem;
        border-radius: 12px;
    }
    .sesion-pago-pendiente {
        background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
        border: 2px solid #f44336;
        animation: pulse-pago 2s infinite;
        padding: 1rem;
        border-radius: 12px;
    }
    @@keyframes pulse-pago {
        0%, 100% { border-color: #f44336; }
        50% { border-color: #d32f2f; box-shadow: 0 0 20px rgba(244, 67, 54, 0.3); }
    }
    .sesion-finalizada {
        background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
        border: 2px solid #4caf50;
        padding: 1rem;
        border-radius: 12px;
    }
    .info-card {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem;
        background: white;
        border-radius: 8px;
        margin-bottom: 0.5rem;
    }
    .info-card .rz-icon {
        font-size: 1.5rem;
        color: var(--rz-primary);
    }
    .monto-total {
        background: var(--rz-success-lighter);
        border: 2px solid var(--rz-success);
    }
    .info-resumen {
        background: white;
        border: 1px solid #ddd;
        padding: 1rem;
        border-radius: 8px;
    }
    .info-resumen-row {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid #eee;
    }
    .info-resumen-row:last-child { border-bottom: none; }
    .cajon-card {
        border-radius: 12px;
        transition: transform 0.2s;
        text-align: center;
        padding: 1rem;
    }
    .cajon-libre {
        background: linear-gradient(180deg, #e8f5e9 0%, #c8e6c9 100%);
        border: 2px solid #4caf50;
    }
    .cajon-ocupado {
        background: linear-gradient(180deg, #ffebee 0%, #ffcdd2 100%);
        border: 2px solid #f44336;
        opacity: 0.8;
    }
    .cajon-emoji { font-size: 3rem; margin-bottom: 0.25rem; }
    .cajon-numero { font-size: 1rem; font-weight: 600; }
    
    .cajones-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
    }
    .badge-libre, .badge-ocupado {
        display: inline-block;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 600;
    }
    .badge-libre { background: #4caf50; color: white; }
    .badge-ocupado { background: #f44336; color: white; }
    
    .pago-botones {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        margin-top: 1rem;
    }
    .pago-btn {
        padding: 1rem;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    .pago-btn-efectivo { background: #4caf50; color: white; }
    .pago-btn-tarjeta { background: #2196f3; color: white; }
    .pago-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    
    /* Tablet+ */
    @@media (min-width: 768px) {
        .page-title { font-size: 1.5rem; }
        .info-card { padding: 1rem; }
        .info-card .rz-icon { font-size: 2rem; }
        .cajon-emoji { font-size: 4rem; }
        .cajones-grid { max-width: 500px; margin: 0 auto; gap: 1.5rem; }
        .pago-botones { flex-direction: row; justify-content: center; }
        .pago-btn { min-width: 180px; }
    }
</style>

@code {
    private List<CajonDto> cajones = new();
    private SesionEstacionamientoDto? sesionActiva;
    private SesionEstacionamientoDto? sesionPendientePago;
    private SesionEstacionamientoDto? sesionFinalizada;
    private TarifaDto? tarifaActual;
    private bool procesandoPago;
    private bool mostrarMensajeDespedida;
    private HubConnection? hubConnection;
    private System.Timers.Timer? actualizadorMonto;

    protected override async Task OnInitializedAsync()
    {
        if (!UsuarioActualService.EstaLogueado || UsuarioActualService.EsAdmin)
        {
            Navigation.NavigateTo("/");
            return;
        }
        
        await LoadData();
        await SetupSignalR();
        SetupActualizadorMonto();
    }

    private async Task LoadData()
    {
        cajones = (await CajonService.GetAllAsync()).ToList();
        tarifaActual = await TarifaService.GetTarifaActivaAsync();
        
        if (UsuarioActualService.UsuarioId.HasValue)
        {
            sesionActiva = await SesionService.GetSesionActivaByUsuarioAsync(UsuarioActualService.UsuarioId.Value);
            sesionPendientePago = await SesionService.GetSesionPendientePagoByUsuarioAsync(UsuarioActualService.UsuarioId.Value);
        }
    }

    private async Task SetupSignalR()
    {
        if (!UsuarioActualService.UsuarioId.HasValue) return;

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/cocherahub"))
            .WithAutomaticReconnect()
            .Build();

        // Nueva sesión creada para este usuario
        hubConnection.On<SesionEstacionamientoDto>("MiNuevaSesion", async (sesion) =>
        {
            sesionActiva = sesion;
            sesionPendientePago = null;
            mostrarMensajeDespedida = false;
            await InvokeAsync(StateHasChanged);
            
            // Mostrar popup de bienvenida
            await InvokeAsync(async () =>
            {
                var resultado = await DialogService.Confirm(
                    $"Se ha iniciado tu sesión en el Cajón {sesion.CajonNumero}. Tarifa: S/ {sesion.TarifaPorMinuto:N2}/min",
                    "🚗 ¡Bienvenido a la Cochera!",
                    new ConfirmOptions 
                    { 
                        OkButtonText = "Ver Mi Estacionamiento", 
                        CancelButtonText = "Cerrar",
                        Width = "400px"
                    });
                
                if (resultado == true)
                {
                    Navigation.NavigateTo("/usuario/estacionamiento", forceLoad: true);
                }
            });
        });

        // Admin solicita cierre de sesión
        hubConnection.On<SesionEstacionamientoDto>("SolicitudCierreSesion", async (sesion) =>
        {
            sesionActiva = null;
            sesionPendientePago = sesion;
            await InvokeAsync(StateHasChanged);
            NotificationService.Notify(NotificationSeverity.Warning, "💰 Hora de pagar", 
                $"Por favor, procede al pago de S/ {sesion.MontoTotal:N2}");
        });

        // Sesión cerrada
        hubConnection.On<SesionEstacionamientoDto>("SesionCerrada", async (sesion) =>
        {
            sesionActiva = null;
            sesionPendientePago = null;
            sesionFinalizada = sesion;
            mostrarMensajeDespedida = true;
            await InvokeAsync(StateHasChanged);
            NotificationService.Notify(NotificationSeverity.Success, "✅ ¡Hasta pronto!", 
                "Tu sesión ha sido cerrada. ¡Gracias por visitarnos!");
            
            // Ocultar mensaje de despedida después de 30 segundos
            _ = Task.Delay(30000).ContinueWith(async _ =>
            {
                mostrarMensajeDespedida = false;
                sesionFinalizada = null;
                await InvokeAsync(StateHasChanged);
            });
        });

        // Actualización de monto en tiempo real
        hubConnection.On<SesionEstacionamientoDto>("ActualizarMontoSesion", async (sesion) =>
        {
            if (sesionActiva != null && sesionActiva.Id == sesion.Id)
            {
                sesionActiva = sesion;
                await InvokeAsync(StateHasChanged);
            }
        });

        // Actualizar cajones en tiempo real
        hubConnection.On<EstadoCocheraDto>("ActualizarCajones", async (estado) =>
        {
            await LoadData();
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
        await hubConnection.InvokeAsync("UnirseComoUsuario", UsuarioActualService.UsuarioId.Value);
    }

    private void SetupActualizadorMonto()
    {
        actualizadorMonto = new System.Timers.Timer(30000); // Cada 30 segundos
        actualizadorMonto.Elapsed += async (sender, e) =>
        {
            if (sesionActiva != null && UsuarioActualService.UsuarioId.HasValue)
            {
                // Refrescar sesión activa para actualizar monto
                sesionActiva = await SesionService.GetSesionActivaByUsuarioAsync(UsuarioActualService.UsuarioId.Value);
                await InvokeAsync(StateHasChanged);
            }
        };
        actualizadorMonto.Start();
    }

    private string GetCajonClass(CajonDto cajon)
    {
        var baseClass = "rz-shadow-3 cajon-card ";
        return cajon.Estado == EstadoCajon.Libre 
            ? baseClass + "cajon-libre" 
            : baseClass + "cajon-ocupado";
    }

    private async Task ConfirmarPago(MetodoPago metodoPago)
    {
        if (sesionPendientePago == null || !UsuarioActualService.UsuarioId.HasValue) return;

        var confirmacion = await DialogService.Confirm(
            $"¿Confirmar pago de S/ {sesionPendientePago.MontoTotal:N2} con {(metodoPago == MetodoPago.Efectivo ? "Efectivo" : "Tarjeta")}?",
            "Confirmar Pago",
            new ConfirmOptions { OkButtonText = "Confirmar Pago", CancelButtonText = "Cancelar" });

        if (confirmacion == true)
        {
            procesandoPago = true;
            try
            {
                var confirmacionPago = new ConfirmacionPagoDto
                {
                    SesionId = sesionPendientePago.Id,
                    UsuarioId = UsuarioActualService.UsuarioId.Value,
                    MetodoPago = metodoPago
                };

                var sesionFinal = await SesionService.ConfirmarPagoUsuarioAsync(confirmacionPago);
                
                // Notificar al admin via SignalR
                await SesionNotificationService.NotificarPagoConfirmadoAsync(sesionFinal);
                
                // La sesión ya está cerrada automáticamente, mostrar mensaje de despedida
                sesionPendientePago = null;
                sesionActiva = null;
                sesionFinalizada = sesionFinal;
                mostrarMensajeDespedida = true;
                
                NotificationService.Notify(NotificationSeverity.Success, "✅ ¡Pago exitoso!", 
                    "Tu pago ha sido procesado. ¡Gracias por visitarnos!");
                
                // Ocultar mensaje de despedida después de 30 segundos
                _ = Task.Delay(30000).ContinueWith(async _ =>
                {
                    mostrarMensajeDespedida = false;
                    sesionFinalizada = null;
                    await InvokeAsync(StateHasChanged);
                });
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
            }
            finally
            {
                procesandoPago = false;
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        actualizadorMonto?.Stop();
        actualizadorMonto?.Dispose();
        
        if (hubConnection != null)
        {
            if (UsuarioActualService.UsuarioId.HasValue)
            {
                await hubConnection.InvokeAsync("SalirDeGrupoUsuario", UsuarioActualService.UsuarioId.Value);
            }
            await hubConnection.DisposeAsync();
        }
    }
}
