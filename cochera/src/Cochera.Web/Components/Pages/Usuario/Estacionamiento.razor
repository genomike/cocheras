        background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
        border: 2px solid #4caf50;
    }
    .cochera-llena {
        background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
        border: 2px solid #f44336;
    }
    .estado-icon {
        font-size: 2.5rem;
    }
    .estado-texto {
        display: flex;
        flex-direction: column;
    }
    .estado-titulo {
        font-size: 1.1rem;
        font-weight: 700;
    }
    .estado-titulo.exito { color: #2e7d32; }
    .estado-titulo.peligro { color: #c62828; }
    .estado-subtitulo {
        font-size: 0.8rem;
        color: #666;
    }
    
    /* Grid de cajones para disponibilidad */
    .cajones-grid-disponibilidad {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    
    .sesion-activa {
        background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
        border: 2px solid #ff9800;
        padding: 1rem;
        border-radius: 12px;
    }
    .sesion-pago-pendiente {
        background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
        border: 2px solid #f44336;
        animation: pulse-pago 2s infinite;
        padding: 1rem;
        border-radius: 12px;
    }
    @@keyframes pulse-pago {
        0%, 100% { border-color: #f44336; }
        50% { border-color: #d32f2f; box-shadow: 0 0 20px rgba(244, 67, 54, 0.3); }
