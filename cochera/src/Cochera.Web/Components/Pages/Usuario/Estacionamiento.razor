@page "/usuario/estacionamiento"
@page "/usuario/disponibilidad"
@attribute [Authorize(Roles = "User")]
@using Cochera.Application.DTOs
@using Cochera.Application.Interfaces
@using Cochera.Web.Services
@using Cochera.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@using Radzen
@using Radzen.Blazor
@inject ICajonService CajonService
@inject ISesionService SesionService
@inject ITarifaService TarifaService
@inject IEstadoCocheraService EstadoCocheraService
@inject ISesionNotificationService SesionNotificationService
@inject UsuarioActualService UsuarioActualService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject DialogService DialogService
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Mi Estacionamiento - Cochera</PageTitle>

@if (!UsuarioActualService.EstaLogueado || UsuarioActualService.EsAdmin)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger">Acceso denegado.</RadzenAlert>
}
else
{
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-mb-4">
        <span class="icon-text" >[VEHICULO]</span> Mi Estacionamiento
    </RadzenText>

    @if (sesionPendientePago != null)
    {
        <!-- ESTADO: Pendiente de Pago -->
        <RadzenCard class="rz-shadow-4 sesion-pago-pendiente rz-mb-4">
            <div style="text-align: center;">
                <span class="icon-text" Style="font-size: 4rem; color: var(--rz-warning);" >[PAGO]</span>
                <RadzenText TextStyle="TextStyle.H4" class="rz-mt-2">
                    ¡Es hora de pagar!
                </RadzenText>
                <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-4">
                    El administrador ha solicitado el cierre de tu sesión.
                </RadzenText>
            </div>

            <RadzenRow Gap="2rem" JustifyContent="JustifyContent.Center">
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenCard class="info-resumen">
                        <RadzenStack Gap="1rem">
                            <RadzenRow>
                                <RadzenColumn Size="6"><strong>Cajón:</strong></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">@sesionPendientePago.CajonNumero</RadzenColumn>
                            </RadzenRow>
                            <RadzenRow>
                                <RadzenColumn Size="6"><strong>Hora entrada:</strong></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">@sesionPendientePago.HoraEntrada.ToString("HH:mm:ss")</RadzenColumn>
                            </RadzenRow>
                            <RadzenRow>
                                <RadzenColumn Size="6"><strong>Hora salida:</strong></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">@(sesionPendientePago.HoraSalida?.ToString("HH:mm:ss") ?? "-")</RadzenColumn>
                            </RadzenRow>
                            <RadzenRow>
                                <RadzenColumn Size="6"><strong>Tiempo total:</strong></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">@sesionPendientePago.TiempoFormateado</RadzenColumn>
                            </RadzenRow>
                            <RadzenRow>
                                <RadzenColumn Size="6"><strong>Tarifa por minuto:</strong></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">S/ @sesionPendientePago.TarifaPorMinuto.ToString("N2")</RadzenColumn>
                            </RadzenRow>
                            <hr />
                            <RadzenRow>
                                <RadzenColumn Size="6"><RadzenText TextStyle="TextStyle.H5">TOTAL A PAGAR:</RadzenText></RadzenColumn>
                                <RadzenColumn Size="6" Style="text-align: right;">
                                    <RadzenText TextStyle="TextStyle.H4" Style="color: var(--rz-success);">
                                        S/ @sesionPendientePago.MontoTotal.ToString("N2")
                                    </RadzenText>
                                </RadzenColumn>
                            </RadzenRow>
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
            </RadzenRow>

            <div style="text-align: center; margin-top: 2rem;">
                @if (sesionPendientePago.TienePago)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success" class="rz-mb-4">
                        <span class="icon-text" >[OK]</span> ¡Pago confirmado! Esperando que el administrador cierre tu sesión...
                    </RadzenAlert>
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-4">Selecciona tu método de pago:</RadzenText>
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" JustifyContent="JustifyContent.Center">
                        <RadzenButton Text="Pagar con Efectivo" Size="ButtonSize.Large"
                            ButtonStyle="ButtonStyle.Success" Click="@(() => ConfirmarPago(MetodoPago.Efectivo))" 
                            IsBusy="@procesandoPago" />
                        <RadzenButton Text="Pagar con Tarjeta" Size="ButtonSize.Large"
                            ButtonStyle="ButtonStyle.Primary" Click="@(() => ConfirmarPago(MetodoPago.Tarjeta))" 
                            IsBusy="@procesandoPago" />
                    </RadzenStack>
                }
            </div>
        </RadzenCard>
    }
    else if (sesionActiva != null)
    {
        <!-- ESTADO: Sesión activa -->
        <RadzenCard class="rz-shadow-4 sesion-activa rz-mb-4">
            <RadzenText TextStyle="TextStyle.H4" class="rz-mb-4">
                <span class="icon-text" >[CAJON]</span> Tienes una sesión activa
            </RadzenText>
            
            <RadzenRow Gap="2rem">
                <RadzenColumn Size="12" SizeMD="6">
                    <div style="text-align: center; font-size: 8rem; margin-bottom: 1rem;">VEHICULO</div>
                    <RadzenText TextStyle="TextStyle.H3" Style="text-align: center;">Cajón @sesionActiva.CajonNumero</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenStack Gap="1rem">
                        <RadzenCard class="info-card">
                            <span class="icon-text" >[HORA]</span>
                            <div>
                                <RadzenText TextStyle="TextStyle.Caption">Hora de entrada</RadzenText>
                                <RadzenText TextStyle="TextStyle.H5">@sesionActiva.HoraEntrada.ToString("HH:mm:ss")</RadzenText>
                            </div>
                        </RadzenCard>
                        <RadzenCard class="info-card">
                            <span class="icon-text" >[TIEMPO]</span>
                            <div>
                                <RadzenText TextStyle="TextStyle.Caption">Tiempo estacionado</RadzenText>
                                <RadzenText TextStyle="TextStyle.H5">@sesionActiva.TiempoFormateado</RadzenText>
                            </div>
                        </RadzenCard>
                        <RadzenCard class="info-card">
                            <span class="icon-text" >[TARIFA]</span>
                            <div>
                                <RadzenText TextStyle="TextStyle.Caption">Tarifa por minuto</RadzenText>
                                <RadzenText TextStyle="TextStyle.H5">S/ @sesionActiva.TarifaPorMinuto.ToString("N2")</RadzenText>
                            </div>
                        </RadzenCard>
                        <RadzenCard class="info-card monto-total">
                            <span class="icon-text" >[PAGO]</span>
                            <div>
                                <RadzenText TextStyle="TextStyle.Caption">Monto acumulado</RadzenText>
                                <RadzenText TextStyle="TextStyle.H3">S/ @sesionActiva.MontoTotal.ToString("N2")</RadzenText>
                            </div>
                        </RadzenCard>
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
            
            <!-- Mensaje informativo: El admin debe solicitar el cierre -->
            <RadzenAlert AlertStyle="AlertStyle.Info" class="rz-mt-4">
                <span class="icon-text" >[INFO]</span> Cuando estés listo para salir, el administrador procesará tu salida y te solicitará el pago.
            </RadzenAlert>
        </RadzenCard>
    }
    else if (sesionFinalizada != null && mostrarMensajeDespedida)
    {
        <!-- ESTADO: Sesión finalizada - Mensaje de despedida -->
        <RadzenCard class="rz-shadow-4 sesion-finalizada rz-mb-4">
            <div style="text-align: center;">
                <div style="font-size: 6rem; margin-bottom: 1rem;">👋</div>
                <RadzenText TextStyle="TextStyle.H3" class="rz-mb-2">¡Gracias por visitarnos!</RadzenText>
                <RadzenText TextStyle="TextStyle.Body1" class="rz-mb-4">Tu sesión ha sido cerrada exitosamente.</RadzenText>
                
                <RadzenCard class="info-resumen" Style="max-width: 400px; margin: 0 auto;">
                    <RadzenStack Gap="0.5rem">
                        <RadzenRow>
                            <RadzenColumn Size="6">Cajón:</RadzenColumn>
                            <RadzenColumn Size="6" Style="text-align: right;">@sesionFinalizada.CajonNumero</RadzenColumn>
                        </RadzenRow>
                        <RadzenRow>
                            <RadzenColumn Size="6">Duración:</RadzenColumn>
                            <RadzenColumn Size="6" Style="text-align: right;">@sesionFinalizada.TiempoFormateado</RadzenColumn>
                        </RadzenRow>
                        <RadzenRow>
                            <RadzenColumn Size="6"><strong>Total pagado:</strong></RadzenColumn>
                            <RadzenColumn Size="6" Style="text-align: right;"><strong>S/ @sesionFinalizada.MontoTotal.ToString("N2")</strong></RadzenColumn>
                        </RadzenRow>
                    </RadzenStack>
                </RadzenCard>
                
                <RadzenButton Text="Ver mi historial" ButtonStyle="ButtonStyle.Primary" 
                    Style="margin-top: 2rem;" Click="@(() => Navigation.NavigateTo("/usuario/historial"))" />
            </div>
        </RadzenCard>
    }
    else
    {
        <!-- ESTADO: Sin sesión activa - MOSTRAR DISPONIBILIDAD -->
        <div class="page-header">
            <span class="icon-text page-icon" >[CAJON]</span>
            <span class="page-title">Mi Estacionamiento</span>
        </div>

        <p class="welcome-text">
            Hola, <strong>@UsuarioActualService.UsuarioActual?.Nombre</strong>!
        </p>

        @if (estadoCochera == null)
        {
            <RadzenProgressBarCircular ShowValue="true" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
        }
        else
        {
            <!-- Resumen del estado -->
            <div class="@($"estado-card {(estadoCochera.CocheraLlena ? "cochera-llena" : "cochera-disponible")}")">
                <div class="estado-icon">
                    @if (estadoCochera.CocheraLlena)
                    {
                        <span>🚫</span>
                    }
                    else
                    {
                        <span>OK</span>
                    }
                </div>
                <div class="estado-texto">
                    @if (estadoCochera.CocheraLlena)
                    {
                        <span class="estado-titulo peligro">COCHERA LLENA</span>
                    }
                    else
                    {
                        <span class="estado-titulo exito">HAY ESPACIO</span>
                    }
                    <span class="estado-subtitulo">@estadoCochera.CajonesLibres de 2 disponibles</span>
                </div>
            </div>

            <!-- Cajones visuales -->
            <div class="cajones-grid-disponibilidad">
                @foreach (var cajon in cajones)
                {
                    <div class="@GetCajonCardClass(cajon)">
                        <div class="cajon-emoji">
                            @if (cajon.Estado == EstadoCajon.Ocupado)
                            {
                                <span>VEHICULO</span>
                            }
                            else
                            {
                                <span>SISTEMA</span>
                            }
                        </div>
                        <div class="cajon-numero">Cajón @cajon.Numero</div>
                        <div class="cajon-estado">
                            @if (cajon.Estado == EstadoCajon.Libre)
                            {
                                <span class="badge-libre">LIBRE</span>
                            }
                            else
                            {
                                <span class="badge-ocupado">OCUPADO</span>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Información de tarifa -->
            @if (tarifaActual != null)
            {
                <RadzenCard class="rz-shadow-3 rz-mt-4">
                    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">
                        <span class="icon-text" >[TARIFA]</span> Información de Tarifa
                    </RadzenText>
                    <RadzenText>Tarifa actual: <strong>S/ @tarifaActual.PrecioPorMinuto.ToString("N2") por minuto</strong></RadzenText>
                    <RadzenText TextStyle="TextStyle.Caption" class="rz-mt-2">
                        * La fracción de minuto se cobra como minuto completo.
                    </RadzenText>
                </RadzenCard>
            }

            <!-- Mensaje informativo -->
            <RadzenAlert AlertStyle="AlertStyle.Info" class="rz-mt-4">
                <span class="icon-text" >[INFO]</span> El administrador registrará tu entrada cuando llegues a la cochera.
            </RadzenAlert>
        }
    }
}

<style>
    /* Mobile-first design */
    .page-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
