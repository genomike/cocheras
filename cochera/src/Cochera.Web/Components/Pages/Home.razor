@page "/"
@using Cochera.Application.DTOs
@using Cochera.Web.Services
@using Radzen
@using Radzen.Blazor
@inject UsuarioActualService UsuarioActualService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Bienvenido - Sistema de Cochera</PageTitle>

<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center;">
    <RadzenIcon Icon="local_parking" Style="font-size: 8rem; color: var(--rz-primary); margin-bottom: 1rem;" />
    
    <RadzenText TextStyle="TextStyle.H2" class="rz-mb-2">
        Sistema de Gestión de Cochera
    </RadzenText>
    
    <RadzenText TextStyle="TextStyle.H5" class="rz-color-secondary rz-mb-4">
        Prototipo de estacionamiento inteligente con sensores ESP32
    </RadzenText>

    <RadzenCard class="rz-shadow-4 rz-p-5" Style="max-width: 500px; width: 100%;">
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-4">
            <RadzenIcon Icon="person" /> Seleccione un usuario para comenzar
        </RadzenText>
        
        <RadzenText TextStyle="TextStyle.Body2" class="rz-color-secondary rz-mb-4">
            Utilice el selector de usuario en el menú lateral izquierdo (parte inferior) para iniciar sesión.
        </RadzenText>

        <RadzenStack Gap="0.5rem">
            @foreach (var usuario in usuarios)
            {
                <RadzenButton Text="@usuario.Nombre" 
                    Icon="@(usuario.EsAdmin ? "admin_panel_settings" : "person")"
                    ButtonStyle="@(usuario.EsAdmin ? ButtonStyle.Warning : ButtonStyle.Primary)" 
                    Variant="Variant.Outlined"
                    Style="width: 100%;"
                    Click="() => SeleccionarUsuario(usuario.Id)" />
            }
        </RadzenStack>
    </RadzenCard>

    <RadzenCard class="rz-mt-4 rz-shadow-2" Style="max-width: 600px;">
        <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">
            <RadzenIcon Icon="info" /> Información del Sistema
        </RadzenText>
        <RadzenStack Gap="0.5rem">
            <RadzenText TextStyle="TextStyle.Body2">🔹 <strong>Admin:</strong> Dashboard, reportes, gestión de tarifas y cajones</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">🔹 <strong>Usuarios:</strong> Ver disponibilidad, estacionar, pagos e historial</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">🔹 <strong>2 Cajones</strong> monitoreados con sensores ultrasónicos</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2">🔹 <strong>Tarifa:</strong> S/ 8.00 por minuto</RadzenText>
        </RadzenStack>
    </RadzenCard>
</div>

@code {
    private List<UsuarioDto> usuarios = new();

    protected override async Task OnInitializedAsync()
    {
        usuarios = (await UsuarioActualService.GetTodosUsuariosAsync()).ToList();
        
        // Si ya hay usuario logueado, redirigir
        if (UsuarioActualService.EstaLogueado)
        {
            if (UsuarioActualService.EsAdmin)
                NavigationManager.NavigateTo("/admin/dashboard");
            else
                NavigationManager.NavigateTo("/usuario/disponibilidad");
        }
    }

    private async Task SeleccionarUsuario(int usuarioId)
    {
        await UsuarioActualService.CambiarUsuarioAsync(usuarioId);
        
        if (UsuarioActualService.EsAdmin)
            NavigationManager.NavigateTo("/admin/dashboard");
        else
            NavigationManager.NavigateTo("/usuario/disponibilidad");
    }
}
