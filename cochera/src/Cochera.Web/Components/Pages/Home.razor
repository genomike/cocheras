@page "/"
@using Cochera.Application.DTOs
@using Cochera.Web.Services
@using Radzen
@using Radzen.Blazor
@inject UsuarioActualService UsuarioActualService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Sistema de Cochera</PageTitle>

@if (!yaRedirigido)
{
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center;">
        <RadzenProgressBarCircular ShowValue="true" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
        <RadzenText TextStyle="TextStyle.Body1" class="rz-mt-4">Cargando...</RadzenText>
    </div>
}

@code {
    private bool yaRedirigido = false;
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !yaRedirigido)
        {
            // Esperar a que el servicio se inicialice desde el storage
            await UsuarioActualService.InitializeAsync();
            
            // Redirigir según el tipo de usuario
            if (UsuarioActualService.EstaLogueado)
            {
                yaRedirigido = true;
                if (UsuarioActualService.EsAdmin)
                    NavigationManager.NavigateTo("/admin/dashboard", forceLoad: false);
                else
                    NavigationManager.NavigateTo("/usuario/estacionamiento", forceLoad: false);
            }
        }
    }
}
