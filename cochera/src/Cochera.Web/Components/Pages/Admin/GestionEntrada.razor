@page "/admin/gestion-entrada"
@attribute [Authorize(Roles = "Admin")]
@using Cochera.Application.DTOs
@using Cochera.Application.Interfaces
@using Cochera.Web.Services
@using Cochera.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@using Radzen
@using Radzen.Blazor
@inject ISesionService SesionService
@inject IUsuarioService UsuarioService
@inject ICajonService CajonService
@inject IEstadoCocheraService EstadoCocheraService
@inject IEventoSensorService EventoSensorService
@inject ISesionNotificationService SesionNotificationService
@inject UsuarioActualService UsuarioActualService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject DialogService DialogService
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Gestión de Entrada/Salida - Admin</PageTitle>

@if (!UsuarioActualService.EsAdmin)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger">Acceso denegado. Esta página es solo para administradores.</RadzenAlert>
}
else
{
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-mb-4">
        <RadzenIcon Icon="directions_car" /> Gestión de Entrada/Salida
    </RadzenText>

    <!-- Barra de Acciones Rápidas -->
    <RadzenCard class="rz-mb-4 rz-p-3">
        <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem">
                <RadzenButton Text="Nuevo Movimiento" Icon="add_circle" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Large"
                    Click="@(() => MostrarDialogoMovimiento(true, null))" />
                <RadzenButton Text="Actualizar" Icon="refresh" ButtonStyle="ButtonStyle.Light"
                    Click="@RefrescarTodo" />
            </RadzenStack>
            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-disabled-color);">
                Última actualización: @ultimaActualizacion.ToString("HH:mm:ss")
            </RadzenText>
        </RadzenStack>
    </RadzenCard>

    <!-- Panel de Notificaciones de Vehículos -->
    <RadzenCard class="@GetNotificacionClass()">
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" class="rz-mb-2">
            <RadzenText TextStyle="TextStyle.H5">
                <RadzenIcon Icon="notifications" /> Notificaciones de Vehículos 
                @if (notificacionesVehiculos.Any())
                {
                    <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="@notificacionesVehiculos.Count.ToString()" />
                }
            </RadzenText>
            @if (notificacionesVehiculos.Any())
            {
                <RadzenButton Text="Limpiar Todo" Icon="clear_all" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                    Click="@LimpiarNotificaciones" />
            }
        </RadzenStack>
        
        @if (notificacionesVehiculos.Any())
        {
            <RadzenStack Gap="0.5rem">
                @foreach (var notif in notificacionesVehiculos)
                {
                    <RadzenCard class="@(notif.TipoEvento == TipoEvento.MovimientoEntrada ? "notif-entrada" : "notif-salida")">
                        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                            <RadzenColumn Size="8">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" AlignItems="AlignItems.Center">
                                    <RadzenIcon Icon="@(notif.TipoEvento == TipoEvento.MovimientoEntrada ? "login" : "logout")" 
                                        Style="font-size: 2rem;" />
                                    <div>
                                        <RadzenText TextStyle="TextStyle.Body1">
                                            <strong>@(notif.TipoEvento == TipoEvento.MovimientoEntrada ? "🚗 Vehículo entrando" : "🚗 Vehículo saliendo")</strong>
                                        </RadzenText>
                                        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-disabled-color);">
                                            @notif.FechaCreacion.ToString("HH:mm:ss") - @notif.Detalle
                                        </RadzenText>
                                    </div>
                                </RadzenStack>
                            </RadzenColumn>
                            <RadzenColumn Size="4" Style="text-align: right;">
                                <RadzenButton Text="Gestionar" Icon="settings" ButtonStyle="ButtonStyle.Info"
                                    Click="@(() => MostrarDialogoMovimiento(notif.TipoEvento == TipoEvento.MovimientoEntrada, notif))" />
                                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                    Click="@(() => DescartarNotificacion(notif))" Style="margin-left: 0.5rem;" />
                            </RadzenColumn>
                        </RadzenRow>
                    </RadzenCard>
                }
            </RadzenStack>
        }
        else
        {
            <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-disabled-color);">
                No hay vehículos pendientes de gestionar. Las notificaciones aparecerán aquí cuando un vehículo sea detectado.
            </RadzenText>
        }
    </RadzenCard>

    <!-- Sesiones Activas y Pendientes de Pago -->
    <RadzenRow Gap="2rem">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard class="rz-shadow-3">
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">
                    <RadzenIcon Icon="directions_car" /> Sesiones Activas
                    <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@sesionesActivas.Count.ToString()" />
                </RadzenText>
                
                @if (sesionesActivas.Any())
                {
                    <RadzenStack Gap="0.5rem">
                        @foreach (var sesion in sesionesActivas)
                        {
                            <RadzenCard class="sesion-card">
                                <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                    <RadzenColumn Size="8">
                                        <RadzenText TextStyle="TextStyle.Body1"><strong>@sesion.UsuarioNombre</strong></RadzenText>
                                        <RadzenText TextStyle="TextStyle.Caption">
                                            Cajón @sesion.CajonNumero | @sesion.TiempoFormateado | S/ @sesion.MontoTotal.ToString("N2")
                                        </RadzenText>
                                    </RadzenColumn>
                                    <RadzenColumn Size="4" Style="text-align: right;">
                                        <RadzenButton Text="Solicitar Salida" Icon="exit_to_app" Size="ButtonSize.Small"
                                            ButtonStyle="ButtonStyle.Warning"
                                            Click="@(() => SolicitarCierreSesion(sesion))" />
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenCard>
                        }
                    </RadzenStack>
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-disabled-color);">
                        No hay sesiones activas.
                    </RadzenText>
                }
            </RadzenCard>
        </RadzenColumn>
        
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenCard class="rz-shadow-3">
                <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">
                    <RadzenIcon Icon="payment" /> Pendientes de Pago
                    <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="@sesionesPendientes.Count.ToString()" />
                </RadzenText>
                
                @if (sesionesPendientes.Any())
                {
                    <RadzenStack Gap="0.5rem">
                        @foreach (var sesion in sesionesPendientes)
                        {
                            <RadzenCard class="@GetSesionPendienteClass(sesion)">
                                <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                    <RadzenColumn Size="8">
                                        <RadzenText TextStyle="TextStyle.Body1">
                                            <strong>@sesion.UsuarioNombre</strong>
                                            @if (sesion.TienePago)
                                            {
                                                <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="PAGADO" Style="margin-left: 0.5rem;" />
                                            }
                                        </RadzenText>
                                        <RadzenText TextStyle="TextStyle.Caption">
                                            Cajón @sesion.CajonNumero | S/ @sesion.MontoTotal.ToString("N2")
                                        </RadzenText>
                                    </RadzenColumn>
                                    <RadzenColumn Size="4" Style="text-align: right;">
                                        @if (sesion.TienePago)
                                        {
                                            <RadzenButton Text="Cerrar Sesión" Icon="check" Size="ButtonSize.Small"
                                                ButtonStyle="ButtonStyle.Success"
                                                Click="@(() => CerrarSesion(sesion))" />
                                        }
                                        else
                                        {
                                            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-warning);">
                                                Esperando pago del usuario...
                                            </RadzenText>
                                        }
                                    </RadzenColumn>
                                </RadzenRow>
                            </RadzenCard>
                        }
                    </RadzenStack>
                }
                else
                {
                    <RadzenText TextStyle="TextStyle.Body1" Style="color: var(--rz-text-disabled-color);">
                        No hay sesiones pendientes de pago.
                    </RadzenText>
                }
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
}

<style>
    .notificacion-activa {
        background: linear-gradient(135deg, #fff3e0 0%, #ffcc80 100%);
        border: 2px solid #ff9800;
        animation: pulse-border 2s infinite;
    }
    @@keyframes pulse-border {
        0%, 100% { border-color: #ff9800; }
        50% { border-color: #f57c00; }
    }
    .notif-entrada {
        background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
        border-left: 4px solid #4caf50;
    }
    .notif-salida {
        background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
        border-left: 4px solid #ff9800;
    }
    .sesion-card {
        background: var(--rz-base-100);
        border-left: 4px solid var(--rz-info);
    }
    .sesion-pendiente-card {
        background: var(--rz-base-100);
        border-left: 4px solid var(--rz-warning);
    }
    .sesion-pendiente-card.pago-confirmado {
        background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
        border-left: 4px solid var(--rz-success);
    }
</style>

@code {
    private List<EventoSensorDto> notificacionesVehiculos = new();
    private List<SesionEstacionamientoDto> sesionesActivas = new();
    private List<SesionEstacionamientoDto> sesionesPendientes = new();
    private List<UsuarioDto> usuarios = new();
    private List<CajonDto> cajonesDisponibles = new();
    private HubConnection? hubConnection;
    private System.Threading.Timer? refreshTimer;
    private DateTime ultimaActualizacion = DateTime.Now;
    private HashSet<int> eventosYaMostrados = new();
    private bool dialogoAbierto = false; // Evita abrir múltiples diálogos

    private string GetNotificacionClass()
    {
        return notificacionesVehiculos.Any() 
            ? "rz-shadow-4 rz-mb-4 notificacion-activa" 
            : "rz-shadow-4 rz-mb-4";
    }

    private string GetSesionPendienteClass(SesionEstacionamientoDto sesion)
    {
        return sesion.TienePago 
            ? "sesion-pendiente-card pago-confirmado" 
            : "sesion-pendiente-card";
    }

    protected override async Task OnInitializedAsync()
    {
        if (!UsuarioActualService.EsAdmin)
        {
            Navigation.NavigateTo("/");
            return;
        }
        
        await LoadData();
        await LoadEventosPendientes();
        await SetupSignalR();
        
        // Timer para refrescar cada 10 segundos como respaldo
        refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadEventosPendientes();
                ultimaActualizacion = DateTime.Now;
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Pequeño delay para asegurar que la UI esté lista
            await Task.Delay(500);
            
            // Si hay notificaciones pendientes, abrir popup automáticamente con la más reciente
            if (notificacionesVehiculos.Any() && !dialogoAbierto)
            {
                var eventoMasReciente = notificacionesVehiculos.First();
                var esEntrada = eventoMasReciente.TipoEvento == TipoEvento.MovimientoEntrada;
                
                dialogoAbierto = true;
                try
                {
                    await MostrarDialogoMovimiento(esEntrada, eventoMasReciente);
                }
                finally
                {
                    dialogoAbierto = false;
                }
            }
        }
    }

    private async Task LoadData()
    {
        sesionesActivas = (await SesionService.GetSesionesActivasAsync()).ToList();
        sesionesPendientes = (await SesionService.GetSesionesPendientesPagoAsync()).ToList();
        usuarios = (await UsuarioService.GetUsuariosNoAdminAsync()).ToList();
        var cajones = (await CajonService.GetAllAsync()).ToList();
        
        // Sincronizar cajones con el estado real de los sensores
        var estadoCochera = await EstadoCocheraService.GetEstadoActualAsync();
        if (estadoCochera != null && cajones.Count >= 2)
        {
            var cajon1 = cajones.FirstOrDefault(c => c.Numero == 1);
            var cajon2 = cajones.FirstOrDefault(c => c.Numero == 2);
            if (cajon1 != null) cajon1.Estado = estadoCochera.Cajon1Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
            if (cajon2 != null) cajon2.Estado = estadoCochera.Cajon2Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
        }
        
        cajonesDisponibles = cajones.Where(c => c.Estado == EstadoCajon.Libre).ToList();
        ultimaActualizacion = DateTime.Now;
    }

    private async Task LoadEventosPendientes()
    {
        try
        {
            // Cargar eventos de entrada de los últimos 30 minutos
            var desde = DateTime.Now.AddMinutes(-30);
            var eventos = await EventoSensorService.GetEventosByFechaAsync(desde, DateTime.Now);
            
            // Filtrar solo eventos de entrada que no hemos mostrado aún
            var eventosEntrada = eventos
                .Where(e => e.TipoEvento == TipoEvento.MovimientoEntrada || e.TipoEvento == TipoEvento.VehiculoSalio)
                .Where(e => !eventosYaMostrados.Contains(e.Id))
                .OrderByDescending(e => e.FechaCreacion)
                .Take(5)
                .ToList();

            foreach (var evento in eventosEntrada)
            {
                if (!notificacionesVehiculos.Any(n => n.Id == evento.Id))
                {
                    notificacionesVehiculos.Insert(0, evento);
                    eventosYaMostrados.Add(evento.Id);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando eventos: {ex.Message}");
        }
    }

    private async Task RefrescarTodo()
    {
        await LoadData();
        await LoadEventosPendientes();
        NotificationService.Notify(NotificationSeverity.Info, "Actualizado", "Datos actualizados correctamente");
    }

    private async Task SetupSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/cocherahub"))
            .WithAutomaticReconnect()
            .Build();

        // Unirse al grupo de admins
        hubConnection.On("Connected", async () =>
        {
            await hubConnection.InvokeAsync("UnirseComoAdmin");
        });

        // Vehículo detectado - abrir automáticamente el diálogo
        hubConnection.On<EventoSensorDto>("VehiculoDetectadoEnEntrada", async (evento) =>
        {
            // NO mostrar popup si es entrada bloqueada (cochera llena)
            if (evento.TipoEvento == TipoEvento.MovimientoEntradaBloqueado || evento.TipoEvento == TipoEvento.CocheraLlena)
            {
                await InvokeAsync(() =>
                {
                    NotificationService.Notify(NotificationSeverity.Warning, 
                        "🚫 Entrada Bloqueada", 
                        "Cochera llena - No se puede ingresar");
                });
                return;
            }
            
            notificacionesVehiculos.Add(evento);
            await InvokeAsync(StateHasChanged);
            
            var esEntrada = evento.TipoEvento == TipoEvento.MovimientoEntrada;
            var esSalida = evento.TipoEvento == TipoEvento.VehiculoSalio;
            
            NotificationService.Notify(NotificationSeverity.Warning, 
                esEntrada ? "🚗 Vehículo entrando" : "🚗 Vehículo saliendo", 
                evento.Detalle);
            
            // Abrir automáticamente el diálogo unificado
            if (!dialogoAbierto)
            {
                dialogoAbierto = true;
                try
                {
                    await InvokeAsync(async () =>
                    {
                        await MostrarDialogoMovimiento(esEntrada, evento);
                    });
                }
                catch (Exception ex)
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
                }
                finally
                {
                    dialogoAbierto = false;
                }
            }
        });

        // Nueva sesión creada
        hubConnection.On<SesionEstacionamientoDto>("NuevaSesionCreada", async (sesion) =>
        {
            sesionesActivas.Add(sesion);
            await LoadData(); // Refrescar cajones disponibles
            await InvokeAsync(StateHasChanged);
        });

        // Usuario confirmó pago
        hubConnection.On<SesionEstacionamientoDto>("UsuarioPagoConfirmado", async (sesion) =>
        {
            var pendiente = sesionesPendientes.FirstOrDefault(s => s.Id == sesion.Id);
            if (pendiente != null)
            {
                var index = sesionesPendientes.IndexOf(pendiente);
                sesionesPendientes[index] = sesion;
            }
            await InvokeAsync(StateHasChanged);
            NotificationService.Notify(NotificationSeverity.Success, "💰 Pago confirmado", 
                $"{sesion.UsuarioNombre} ha pagado S/ {sesion.MontoTotal:N2}");
        });

        // Sesión cerrada
        hubConnection.On<SesionEstacionamientoDto>("SesionCerradaAdmin", async (sesion) =>
        {
            sesionesPendientes.RemoveAll(s => s.Id == sesion.Id);
            await LoadData(); // Refrescar cajones disponibles
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
        await hubConnection.InvokeAsync("UnirseComoAdmin");
    }

    private void DescartarNotificacion(EventoSensorDto evento)
    {
        notificacionesVehiculos.Remove(evento);
    }

    private void LimpiarNotificaciones()
    {
        notificacionesVehiculos.Clear();
    }

    private async Task MostrarDialogoNuevaSesion()
    {
        await MostrarDialogoMovimiento(true, null);
    }

    private async Task MostrarDialogoSalidaManual()
    {
        await MostrarDialogoMovimiento(false, null);
    }

    private async Task MostrarDialogoEntrada(EventoSensorDto evento)
    {
        await MostrarDialogoMovimiento(true, evento);
    }

    private async Task MostrarDialogoSalida(EventoSensorDto evento)
    {
        await MostrarDialogoMovimiento(false, evento);
    }

    /// <summary>
    /// Muestra el diálogo unificado de movimiento (entrada/salida)
    /// </summary>
    private async Task MostrarDialogoMovimiento(bool esEntrada, EventoSensorDto? evento = null)
    {
        // Refrescar datos
        usuarios = (await UsuarioService.GetUsuariosNoAdminAsync()).ToList();
        var cajones = await CajonService.GetAllAsync();
        cajonesDisponibles = cajones.Where(c => c.Estado == EstadoCajon.Libre).ToList();
        sesionesActivas = (await SesionService.GetSesionesActivasAsync()).ToList();

        // Filtrar usuarios que no tengan sesión activa
        var usuariosDisponibles = usuarios.Where(u => 
            !sesionesActivas.Any(s => s.UsuarioId == u.Id) &&
            !sesionesPendientes.Any(s => s.UsuarioId == u.Id)).ToList();

        // Mostrar diálogo unificado
        var result = await DialogService.OpenAsync<DialogoMovimiento>(
            esEntrada ? "🚗 Registrar Movimiento - Entrada" : "🚗 Registrar Movimiento - Salida",
            new Dictionary<string, object>
            {
                { "UsuariosDisponibles", usuariosDisponibles },
                { "CajonesDisponibles", cajonesDisponibles },
                { "SesionesActivas", sesionesActivas },
                { "ModoEntradaInicial", esEntrada }
            },
            new DialogOptions
            {
                Width = "600px",
                Height = "auto",
                CloseDialogOnOverlayClick = false
            });

        if (result is DialogoMovimiento.MovimientoResult movimiento)
        {
            if (movimiento.TipoMovimiento == "Entrada" && movimiento.DatosEntrada != null)
            {
                // Registrar entrada
                try
                {
                    var sesion = await SesionService.IniciarSesionAsync(movimiento.DatosEntrada);
                    if (evento != null) notificacionesVehiculos.Remove(evento);
                    await LoadData();
                    
                    await SesionNotificationService.NotificarNuevaSesionAsync(sesion);
                    
                    NotificationService.Notify(NotificationSeverity.Success, "✅ Sesión iniciada", 
                        $"Usuario {sesion.UsuarioNombre} en Cajón {sesion.CajonNumero}");
                }
                catch (Exception ex)
                {
                    NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
                }
            }
            else if (movimiento.TipoMovimiento == "Salida" && movimiento.SesionSalida != null)
            {
                // Solicitar salida
                await SolicitarCierreSesion(movimiento.SesionSalida);
                if (evento != null) notificacionesVehiculos.Remove(evento);
            }
        }
    }

    private async Task SolicitarCierreSesion(SesionEstacionamientoDto sesion)
    {
        var confirmacion = await DialogService.Confirm(
            $"¿Solicitar cierre de sesión para {sesion.UsuarioNombre}?\n\nMonto actual: S/ {sesion.MontoTotal:N2}\n\nEl usuario recibirá una notificación para proceder al pago.",
            "Confirmar solicitud de salida",
            new ConfirmOptions { OkButtonText = "Solicitar", CancelButtonText = "Cancelar" });

        if (confirmacion == true)
        {
            try
            {
                var sesionActualizada = await SesionService.SolicitarCierreSesionAsync(sesion.Id);
                
                // Mover de activas a pendientes
                sesionesActivas.RemoveAll(s => s.Id == sesion.Id);
                sesionesPendientes.Add(sesionActualizada);
                
                // Notificar via SignalR al usuario
                await SesionNotificationService.NotificarSolicitudCierreSesionAsync(sesionActualizada);
                
                NotificationService.Notify(NotificationSeverity.Info, "📤 Solicitud enviada", 
                    $"Se notificó a {sesion.UsuarioNombre} para que proceda al pago.");
                
                StateHasChanged();
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
            }
        }
    }

    private async Task CerrarSesion(SesionEstacionamientoDto sesion)
    {
        try
        {
            var sesionCerrada = await SesionService.CerrarSesionAsync(sesion.Id);
            sesionesPendientes.RemoveAll(s => s.Id == sesion.Id);
            await LoadData();
            
            // Notificar via SignalR
            await SesionNotificationService.NotificarSesionCerradaAsync(sesionCerrada);
            
            NotificationService.Notify(NotificationSeverity.Success, "✅ Sesión cerrada", 
                $"Sesión de {sesion.UsuarioNombre} cerrada exitosamente. Cajón {sesion.CajonNumero} liberado.");
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
    }

    public async ValueTask DisposeAsync()
    {
        refreshTimer?.Dispose();
        if (hubConnection != null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
