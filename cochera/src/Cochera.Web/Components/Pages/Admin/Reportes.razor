@page "/admin/reportes"
@using Cochera.Application.DTOs
@using Cochera.Application.Interfaces
@using Radzen
@using Radzen.Blazor
@inject IDashboardService DashboardService
@inject ISesionService SesionService
@rendermode InteractiveServer

<PageTitle>Reportes - Cochera</PageTitle>

<RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-mb-4">
    <RadzenIcon Icon="bar_chart" /> Reportes y Estadísticas
</RadzenText>

<RadzenCard class="rz-mb-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Wrap="FlexWrap.Wrap">
        <RadzenFormField Text="Desde" Variant="Variant.Outlined">
            <RadzenDatePicker @bind-Value="@fechaDesde" DateFormat="dd/MM/yyyy" />
        </RadzenFormField>
        <RadzenFormField Text="Hasta" Variant="Variant.Outlined">
            <RadzenDatePicker @bind-Value="@fechaHasta" DateFormat="dd/MM/yyyy" />
        </RadzenFormField>
        <RadzenButton Text="Generar Reporte" Icon="assessment" Click="@GenerarReporte" />
        <RadzenButton Text="Este Mes" Icon="calendar_month" ButtonStyle="ButtonStyle.Light" Click="@FiltrarMes" />
    </RadzenStack>
</RadzenCard>

<RadzenRow Gap="1rem" class="rz-mb-4">
    <RadzenColumn Size="12" SizeMD="3">
        <RadzenCard class="rz-shadow-3" Style="text-align: center;">
            <RadzenIcon Icon="receipt" Style="font-size: 2rem; color: var(--rz-primary);" />
            <RadzenText TextStyle="TextStyle.Overline">Total Sesiones</RadzenText>
            <RadzenText TextStyle="TextStyle.H3">@totalSesiones</RadzenText>
        </RadzenCard>
    </RadzenColumn>
    <RadzenColumn Size="12" SizeMD="3">
        <RadzenCard class="rz-shadow-3" Style="text-align: center;">
            <RadzenIcon Icon="schedule" Style="font-size: 2rem; color: var(--rz-info);" />
            <RadzenText TextStyle="TextStyle.Overline">Minutos Totales</RadzenText>
            <RadzenText TextStyle="TextStyle.H3">@totalMinutos</RadzenText>
        </RadzenCard>
    </RadzenColumn>
    <RadzenColumn Size="12" SizeMD="3">
        <RadzenCard class="rz-shadow-3" Style="text-align: center;">
            <RadzenIcon Icon="payments" Style="font-size: 2rem; color: var(--rz-success);" />
            <RadzenText TextStyle="TextStyle.Overline">Recaudación Total</RadzenText>
            <RadzenText TextStyle="TextStyle.H3">S/ @totalRecaudacion.ToString("N2")</RadzenText>
        </RadzenCard>
    </RadzenColumn>
    <RadzenColumn Size="12" SizeMD="3">
        <RadzenCard class="rz-shadow-3" Style="text-align: center;">
            <RadzenIcon Icon="trending_up" Style="font-size: 2rem; color: var(--rz-warning);" />
            <RadzenText TextStyle="TextStyle.Overline">Promedio/Día</RadzenText>
            <RadzenText TextStyle="TextStyle.H3">S/ @promedioDia.ToString("N2")</RadzenText>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

<RadzenRow Gap="1rem">
    <RadzenColumn Size="12" SizeMD="6">
        <RadzenCard class="rz-shadow-3">
            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">
                <RadzenIcon Icon="show_chart" /> Recaudación por Día
            </RadzenText>
            <RadzenChart Style="height: 300px;">
                <RadzenLineSeries Data="@datosPorDia" CategoryProperty="FechaTexto" ValueProperty="Recaudacion" Title="Recaudación" Smooth="true">
                    <RadzenMarkers MarkerType="MarkerType.Circle" />
                </RadzenLineSeries>
                <RadzenCategoryAxis>
                    <RadzenAxisTitle Text="Fecha" />
                </RadzenCategoryAxis>
                <RadzenValueAxis>
                    <RadzenAxisTitle Text="S/" />
                </RadzenValueAxis>
                <RadzenLegend Visible="false" />
            </RadzenChart>
        </RadzenCard>
    </RadzenColumn>
    <RadzenColumn Size="12" SizeMD="6">
        <RadzenCard class="rz-shadow-3">
            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">
                <RadzenIcon Icon="bar_chart" /> Sesiones por Día
            </RadzenText>
            <RadzenChart Style="height: 300px;">
                <RadzenColumnSeries Data="@datosPorDia" CategoryProperty="FechaTexto" ValueProperty="CantidadSesiones" Title="Sesiones">
                    <RadzenSeriesDataLabels Visible="true" />
                </RadzenColumnSeries>
                <RadzenCategoryAxis>
                    <RadzenAxisTitle Text="Fecha" />
                </RadzenCategoryAxis>
                <RadzenValueAxis>
                    <RadzenAxisTitle Text="Sesiones" />
                </RadzenValueAxis>
                <RadzenLegend Visible="false" />
            </RadzenChart>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

<RadzenRow Gap="1rem" class="rz-mt-4">
    <RadzenColumn Size="12">
        <RadzenCard class="rz-shadow-3">
            <RadzenText TextStyle="TextStyle.H6" class="rz-mb-2">
                <RadzenIcon Icon="pie_chart" /> Distribución de Uso por Hora (Promedio)
            </RadzenText>
            <RadzenChart Style="height: 300px;">
                <RadzenAreaSeries Data="@datosPorHora" CategoryProperty="Hora" ValueProperty="CantidadSesiones" Title="Sesiones" Smooth="true" />
                <RadzenCategoryAxis>
                    <RadzenAxisTitle Text="Hora del día" />
                </RadzenCategoryAxis>
                <RadzenValueAxis>
                    <RadzenAxisTitle Text="Promedio Sesiones" />
                </RadzenValueAxis>
                <RadzenLegend Visible="false" />
            </RadzenChart>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    private DateTime fechaDesde = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
    private DateTime fechaHasta = DateTime.Today;
    private int totalSesiones;
    private int totalMinutos;
    private decimal totalRecaudacion;
    private decimal promedioDia;
    private List<ResumenDiaView> datosPorDia = new();
    private List<ResumenPorHora> datosPorHora = new();

    protected override async Task OnInitializedAsync()
    {
        await GenerarReporte();
    }

    private async Task GenerarReporte()
    {
        var sesiones = await SesionService.GetSesionesByFechaAsync(fechaDesde, fechaHasta.AddDays(1).AddSeconds(-1));
        var listaSesiones = sesiones.ToList();

        totalSesiones = listaSesiones.Count;
        totalMinutos = listaSesiones.Sum(s => s.MinutosEstacionado);
        totalRecaudacion = listaSesiones.Sum(s => s.MontoTotal);

        var dias = (fechaHasta - fechaDesde).Days + 1;
        promedioDia = dias > 0 ? totalRecaudacion / dias : 0;

        // Datos por día
        var usoPorDia = await DashboardService.GetUsoPorDiaAsync(fechaDesde, fechaHasta);
        datosPorDia = usoPorDia.Select(d => new ResumenDiaView
        {
            Fecha = d.Fecha,
            FechaTexto = d.Fecha.ToString("dd/MM"),
            CantidadSesiones = d.CantidadSesiones,
            Recaudacion = d.Recaudacion
        }).ToList();

        // Datos por hora (promedio)
        datosPorHora = await Task.Run(() =>
        {
            var resultado = new List<ResumenPorHora>();
            for (int hora = 0; hora < 24; hora++)
            {
                var sesionesHora = listaSesiones.Count(s => s.HoraEntrada.Hour == hora);
                resultado.Add(new ResumenPorHora
                {
                    Hora = hora,
                    CantidadSesiones = sesionesHora
                });
            }
            return resultado;
        });
    }

    private async Task FiltrarMes()
    {
        fechaDesde = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
        fechaHasta = DateTime.Today;
        await GenerarReporte();
    }

    private class ResumenDiaView
    {
        public DateTime Fecha { get; set; }
        public string FechaTexto { get; set; } = string.Empty;
        public int CantidadSesiones { get; set; }
        public decimal Recaudacion { get; set; }
    }
}
