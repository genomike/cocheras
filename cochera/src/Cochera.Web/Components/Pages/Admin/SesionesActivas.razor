@page "/admin/sesiones"
@attribute [Authorize(Roles = "Admin")]
@using Cochera.Application.DTOs
@using Cochera.Application.Interfaces
@using Cochera.Web.Services
@using Cochera.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@using Radzen
@using Radzen.Blazor
@inject ISesionService SesionService
@inject ISesionNotificationService SesionNotificationService
@inject UsuarioActualService UsuarioActualService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@inject DialogService DialogService
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Sesiones Activas - Admin</PageTitle>

@if (!UsuarioActualService.EsAdmin)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger">Acceso denegado. Esta página es solo para administradores.</RadzenAlert>
}
else
{
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-mb-4">
        <span class="icon-text" >[CAJON]</span> Sesiones de Estacionamiento
    </RadzenText>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" class="rz-mb-4">
        <RadzenButton Text="Actualizar" Click="@LoadSesiones" />
        <RadzenButton Text="Gestión de Entrada/Salida" 
            ButtonStyle="ButtonStyle.Primary" Click="@(() => Navigation.NavigateTo("/admin/gestion-entrada"))" />
    </RadzenStack>

    <!-- Sesiones Activas -->
    <RadzenCard class="rz-shadow-3 rz-mb-4">
        <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">
            <span class="icon-text" >[ACTIVA]</span> Sesiones Activas
            <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@sesionesActivas.Count.ToString()" />
        </RadzenText>
        
        @if (sesionesActivas.Any())
        {
            <RadzenDataGrid Data="@sesionesActivas" TItem="SesionEstacionamientoDto" AllowPaging="true" PageSize="10">
                <Columns>
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Property="Id" Title="ID" Width="60px" />
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Property="UsuarioNombre" Title="Usuario" />
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Property="CajonNumero" Title="Cajón" Width="80px" TextAlign="TextAlign.Center" />
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Property="HoraEntrada" Title="Hora Entrada" FormatString="{0:dd/MM HH:mm:ss}" Width="140px" />
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Title="Tiempo" Width="100px">
                        <Template Context="sesion">
                            @sesion.TiempoFormateado
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Property="TarifaPorMinuto" Title="Tarifa/Min" FormatString="S/ {0:N2}" Width="100px" />
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Title="Monto" Width="120px">
                        <Template Context="sesion">
                            <strong style="color: var(--rz-success);">S/ @sesion.MontoTotal.ToString("N2")</strong>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Title="Estado" Width="100px">
                        <Template Context="sesion">
                            <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="En curso" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Title="Acciones" Width="150px">
                        <Template Context="sesion">
                            <RadzenButton Text="Salida" Size="ButtonSize.Small"
                                ButtonStyle="ButtonStyle.Warning" Click="@(() => SolicitarCierre(sesion))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
        else
        {
            <RadzenAlert AlertStyle="AlertStyle.Info">
                No hay sesiones activas en este momento.
            </RadzenAlert>
        }
    </RadzenCard>

    <!-- Sesiones Pendientes de Pago -->
    <RadzenCard class="rz-shadow-3 rz-mb-4">
        <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">
            <span class="icon-text" >[PAGO]</span> Pendientes de Pago
            <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="@sesionesPendientes.Count.ToString()" />
        </RadzenText>
        
        @if (sesionesPendientes.Any())
        {
            <RadzenDataGrid Data="@sesionesPendientes" TItem="SesionEstacionamientoDto" AllowPaging="true" PageSize="10">
                <Columns>
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Property="Id" Title="ID" Width="60px" />
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Property="UsuarioNombre" Title="Usuario" />
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Property="CajonNumero" Title="Cajón" Width="80px" TextAlign="TextAlign.Center" />
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Title="Tiempo" Width="100px">
                        <Template Context="sesion">
                            @sesion.TiempoFormateado
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Title="Monto" Width="120px">
                        <Template Context="sesion">
                            <strong style="color: var(--rz-success);">S/ @sesion.MontoTotal.ToString("N2")</strong>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Title="Estado Pago" Width="120px">
                        <Template Context="sesion">
                            @if (sesion.TienePago)
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="PAGADO OK" />
                            }
                            else
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="Esperando..." />
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SesionEstacionamientoDto" Title="Acciones" Width="150px">
                        <Template Context="sesion">
                            @if (sesion.TienePago)
                            {
                                <RadzenButton Text="Cerrar" Size="ButtonSize.Small"
                                    ButtonStyle="ButtonStyle.Success" Click="@(() => CerrarSesion(sesion))" />
                            }
                            else
                            {
                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-disabled-color);">
                                    Esperando pago del usuario
                                </RadzenText>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        }
        else
        {
            <RadzenAlert AlertStyle="AlertStyle.Info">
                No hay sesiones pendientes de pago.
            </RadzenAlert>
        }
    </RadzenCard>
}

@code {
    private List<SesionEstacionamientoDto> sesionesActivas = new();
    private List<SesionEstacionamientoDto> sesionesPendientes = new();
    private HubConnection? hubConnection;
    private System.Timers.Timer? actualizadorAutomatico;

    protected override async Task OnInitializedAsync()
    {
        if (!UsuarioActualService.EsAdmin)
        {
            Navigation.NavigateTo("/");
            return;
        }
        
        await LoadSesiones();
        await SetupSignalR();
        SetupActualizadorAutomatico();
    }
    
    private void SetupActualizadorAutomatico()
    {
        // Actualizar cada 30 segundos para mantener tiempos y montos frescos
        actualizadorAutomatico = new System.Timers.Timer(30000);
        actualizadorAutomatico.Elapsed += async (sender, e) =>
        {
            await LoadSesiones();
            await InvokeAsync(StateHasChanged);
        };
        actualizadorAutomatico.Start();
    }

    private async Task LoadSesiones()
    {
        sesionesActivas = (await SesionService.GetSesionesActivasAsync()).ToList();
        sesionesPendientes = (await SesionService.GetSesionesPendientesPagoAsync()).ToList();
    }

    private async Task SetupSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/cocherahub"))
            .WithAutomaticReconnect()
            .Build();

        // Nueva sesión iniciada
        hubConnection.On<SesionEstacionamientoDto>("NuevaSesionCreada", async (sesion) =>
        {
            sesionesActivas.Add(sesion);
            await InvokeAsync(StateHasChanged);
            NotificationService.Notify(NotificationSeverity.Info, "Nueva sesión", 
                $"Usuario {sesion.UsuarioNombre} en Cajón {sesion.CajonNumero}");
        });

        // Usuario confirmó pago
        hubConnection.On<SesionEstacionamientoDto>("UsuarioPagoConfirmado", async (sesion) =>
        {
            var pendiente = sesionesPendientes.FirstOrDefault(s => s.Id == sesion.Id);
            if (pendiente != null)
            {
                var index = sesionesPendientes.IndexOf(pendiente);
                sesionesPendientes[index] = sesion;
            }
            await InvokeAsync(StateHasChanged);
            NotificationService.Notify(NotificationSeverity.Success, "💰 Pago confirmado", 
                $"{sesion.UsuarioNombre} ha pagado S/ {sesion.MontoTotal:N2}");
        });

        // Sesión cerrada
        hubConnection.On<SesionEstacionamientoDto>("SesionCerradaAdmin", async (sesion) =>
        {
            sesionesActivas.RemoveAll(s => s.Id == sesion.Id);
            sesionesPendientes.RemoveAll(s => s.Id == sesion.Id);
            await InvokeAsync(StateHasChanged);
            NotificationService.Notify(NotificationSeverity.Success, "Sesión cerrada", 
                $"Sesión de {sesion.UsuarioNombre} cerrada - Cajón {sesion.CajonNumero} liberado");
        });

        await hubConnection.StartAsync();
    }

    private async Task SolicitarCierre(SesionEstacionamientoDto sesion)
    {
        var confirmacion = await DialogService.Confirm(
            $"¿Solicitar cierre de sesión para {sesion.UsuarioNombre}?\n\nMonto actual: S/ {sesion.MontoTotal:N2}\n\nEl usuario recibirá una notificación para proceder al pago.",
            "Confirmar solicitud de salida",
            new ConfirmOptions { OkButtonText = "Solicitar", CancelButtonText = "Cancelar" });

        if (confirmacion == true)
        {
            try
            {
                var sesionActualizada = await SesionService.SolicitarCierreSesionAsync(sesion.Id);
                
                // Mover de activas a pendientes
                sesionesActivas.RemoveAll(s => s.Id == sesion.Id);
                sesionesPendientes.Add(sesionActualizada);
                
                // Notificar via SignalR al usuario
                await SesionNotificationService.NotificarSolicitudCierreSesionAsync(sesionActualizada);
                
                NotificationService.Notify(NotificationSeverity.Info, "📤 Solicitud enviada", 
                    $"Se notificó a {sesion.UsuarioNombre} para que proceda al pago.");
                
                StateHasChanged();
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
            }
        }
    }

    private async Task CerrarSesion(SesionEstacionamientoDto sesion)
    {
        try
        {
            var sesionCerrada = await SesionService.CerrarSesionAsync(sesion.Id);
            sesionesPendientes.RemoveAll(s => s.Id == sesion.Id);
            
            // Notificar via SignalR
            await SesionNotificationService.NotificarSesionCerradaAsync(sesionCerrada);
            
            NotificationService.Notify(NotificationSeverity.Success, "OK Sesión cerrada", 
                $"Sesión de {sesion.UsuarioNombre} cerrada exitosamente. Cajón {sesion.CajonNumero} liberado.");
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
    }

    public async ValueTask DisposeAsync()
    {
        actualizadorAutomatico?.Stop();
        actualizadorAutomatico?.Dispose();
        
        if (hubConnection != null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}


