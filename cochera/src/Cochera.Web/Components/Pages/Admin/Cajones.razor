@page "/admin/cajones"
@attribute [Authorize(Roles = "Admin")]
@using Cochera.Application.DTOs
@using Cochera.Application.Interfaces
@using Cochera.Web.Services
@using Cochera.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@using Radzen
@using Radzen.Blazor
@inject ICajonService CajonService
@inject IEstadoCocheraService EstadoCocheraService
@inject UsuarioActualService UsuarioActualService
@inject NavigationManager Navigation
@inject NotificationService NotificationService
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Gestión de Cajones - Admin</PageTitle>

@if (!UsuarioActualService.EsAdmin)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger">Acceso denegado. Esta página es solo para administradores.</RadzenAlert>
}
else
{
    <RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-mb-4">
        <span class="icon-text" >[CAJON]</span> Gestión de Cajones
    </RadzenText>

    <RadzenButton Text="Actualizar" Click="@LoadCajones" class="rz-mb-4" />

    <RadzenRow Gap="1rem">
        @foreach (var cajon in cajones)
        {
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenCard class="@($"rz-shadow-4 cajon-card {(cajon.Estado == EstadoCajon.Ocupado ? "ocupado" : "libre")}")">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                        <div>
                            <RadzenText TextStyle="TextStyle.H4">
                                <span class="icon-text" >[CAJON]</span> Cajón @cajon.Numero
                            </RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1" class="rz-mt-2">
                                Estado: 
                                @if (cajon.Estado == EstadoCajon.Libre)
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="OK Libre" />
                                }
                                else
                                {
                                    <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="VEHICULO Ocupado" />
                                }
                            </RadzenText>
                            @if (cajon.UltimoCambioEstado.HasValue)
                            {
                                <RadzenText TextStyle="TextStyle.Caption" class="rz-color-secondary">
                                    Último cambio: @cajon.UltimoCambioEstado.Value.ToString("dd/MM/yyyy HH:mm:ss")
                                </RadzenText>
                            }
                        </div>
                        <div style="font-size: 5rem;">
                            @if (cajon.Estado == EstadoCajon.Ocupado)
                            {
                                <span>VEHICULO</span>
                            }
                            else
                            {
                                <span>SISTEMA</span>
                            }
                        </div>
                    </RadzenStack>
                </RadzenCard>
            </RadzenColumn>
        }
    </RadzenRow>

    <RadzenCard class="rz-shadow-3 rz-mt-4">
        <RadzenText TextStyle="TextStyle.H5" class="rz-mb-4">
            <span class="icon-text" >[INFO]</span> Información de Cajones
        </RadzenText>
        <RadzenDataGrid Data="@cajones" TItem="CajonDto">
            <Columns>
                <RadzenDataGridColumn TItem="CajonDto" Property="Id" Title="ID" Width="60px" />
                <RadzenDataGridColumn TItem="CajonDto" Property="Numero" Title="Número" Width="80px" />
                <RadzenDataGridColumn TItem="CajonDto" Property="EstadoTexto" Title="Estado" />
                <RadzenDataGridColumn TItem="CajonDto" Property="UltimoCambioEstado" Title="Último Cambio" FormatString="{0:dd/MM/yyyy HH:mm:ss}" />
                <RadzenDataGridColumn TItem="CajonDto" Property="FechaCreacion" Title="Fecha Creación" FormatString="{0:dd/MM/yyyy}" />
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>

    <RadzenCard class="rz-shadow-2 rz-mt-4">
        <RadzenText TextStyle="TextStyle.H6">
            <span class="icon-text" >[RESUMEN]</span> Resumen
        </RadzenText>
        <RadzenText>
            <strong>Libres:</strong> @cajones.Count(c => c.Estado == EstadoCajon.Libre) |
            <strong>Ocupados:</strong> @cajones.Count(c => c.Estado == EstadoCajon.Ocupado)
        </RadzenText>
    </RadzenCard>
}

<style>
    .cajon-card {
        padding: 1.5rem;
        border-radius: 12px;
        transition: transform 0.2s;
    }
    .cajon-card:hover {
        transform: translateY(-4px);
    }
    .cajon-card.libre {
        background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
        border-left: 5px solid #4caf50;
    }
    .cajon-card.ocupado {
        background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
        border-left: 5px solid #f44336;
    }
</style>

@code {
    private List<CajonDto> cajones = new();
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        if (!UsuarioActualService.EsAdmin)
        {
            Navigation.NavigateTo("/");
            return;
        }
        
        await LoadCajones();
        await SetupSignalR();
    }

    private async Task LoadCajones()
    {
        cajones = (await CajonService.GetAllAsync()).ToList();
        
        // Sincronizar con el estado real de los sensores
        var estadoCochera = await EstadoCocheraService.GetEstadoActualAsync();
        if (estadoCochera != null && cajones.Count >= 2)
        {
            var cajon1 = cajones.FirstOrDefault(c => c.Numero == 1);
            var cajon2 = cajones.FirstOrDefault(c => c.Numero == 2);
            if (cajon1 != null) cajon1.Estado = estadoCochera.Cajon1Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
            if (cajon2 != null) cajon2.Estado = estadoCochera.Cajon2Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
        }
    }
    
    private async Task SetupSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/cocherahub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<EstadoCocheraDto>("RecibirEstado", async (estado) =>
        {
            if (cajones.Count >= 2)
            {
                var cajon1 = cajones.FirstOrDefault(c => c.Numero == 1);
                var cajon2 = cajones.FirstOrDefault(c => c.Numero == 2);
                if (cajon1 != null) cajon1.Estado = estado.Cajon1Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
                if (cajon2 != null) cajon2.Estado = estado.Cajon2Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
            }
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.On<EstadoCocheraDto>("ActualizarCajones", async (estado) =>
        {
            if (cajones.Count >= 2)
            {
                var cajon1 = cajones.FirstOrDefault(c => c.Numero == 1);
                var cajon2 = cajones.FirstOrDefault(c => c.Numero == 2);
                if (cajon1 != null) cajon1.Estado = estado.Cajon1Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
                if (cajon2 != null) cajon2.Estado = estado.Cajon2Ocupado ? EstadoCajon.Ocupado : EstadoCajon.Libre;
            }
            await InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}


