@page "/eventos"
@using Cochera.Application.DTOs
@using Cochera.Application.Interfaces
@using Microsoft.AspNetCore.SignalR.Client
@using Radzen
@using Radzen.Blazor
@inject IEventoSensorService EventoService
@inject NavigationManager Navigation
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Eventos Sensores - Cochera</PageTitle>

<RadzenText TextStyle="TextStyle.H3" TagName="TagName.H1" class="rz-mb-4">
    <RadzenIcon Icon="sensors" /> Eventos de Sensores
</RadzenText>

<RadzenCard class="rz-mb-4">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem" Wrap="FlexWrap.Wrap">
        <RadzenFormField Text="Desde" Variant="Variant.Outlined">
            <RadzenDatePicker @bind-Value="@fechaDesde" ShowTime="true" DateFormat="dd/MM/yyyy HH:mm" />
        </RadzenFormField>
        <RadzenFormField Text="Hasta" Variant="Variant.Outlined">
            <RadzenDatePicker @bind-Value="@fechaHasta" ShowTime="true" DateFormat="dd/MM/yyyy HH:mm" />
        </RadzenFormField>
        <RadzenButton Text="Filtrar" Icon="filter_alt" Click="@FiltrarEventos" />
        <RadzenButton Text="Últimos 50" Icon="refresh" ButtonStyle="ButtonStyle.Light" Click="@CargarUltimos" />
        
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Style="margin-left: auto;">
            <RadzenBadge BadgeStyle="@(conectado ? BadgeStyle.Success : BadgeStyle.Danger)" 
                Text="@(conectado ? "🟢 En Vivo" : "🔴 Desconectado")" />
        </RadzenStack>
    </RadzenStack>
</RadzenCard>

<RadzenDataGrid @ref="grid" Data="@eventos" TItem="EventoSensorDto" 
    AllowPaging="true" PageSize="20" PagerHorizontalAlign="HorizontalAlign.Center"
    AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple"
    class="rz-shadow-3">
    <Columns>
        <RadzenDataGridColumn TItem="EventoSensorDto" Property="Id" Title="ID" Width="60px" Frozen="true" />
        <RadzenDataGridColumn TItem="EventoSensorDto" Property="FechaCreacion" Title="Fecha/Hora" Width="160px" FormatString="{0:dd/MM/yy HH:mm:ss}" />
        <RadzenDataGridColumn TItem="EventoSensorDto" Property="TipoEventoTexto" Title="Evento" Width="160px">
            <Template Context="evento">
                <RadzenBadge BadgeStyle="@GetBadgeStyle(evento.TipoEvento)" Text="@evento.TipoEventoTexto" />
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="EventoSensorDto" Property="Detalle" Title="Detalle" />
        <RadzenDataGridColumn TItem="EventoSensorDto" Property="EstadoCajon1" Title="Cajón 1" Width="100px">
            <Template Context="evento">
                <RadzenBadge BadgeStyle="@(evento.EstadoCajon1 == "OCUPADO" ? BadgeStyle.Danger : BadgeStyle.Success)" 
                    Text="@evento.EstadoCajon1" />
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="EventoSensorDto" Property="EstadoCajon2" Title="Cajón 2" Width="100px">
            <Template Context="evento">
                <RadzenBadge BadgeStyle="@(evento.EstadoCajon2 == "OCUPADO" ? BadgeStyle.Danger : BadgeStyle.Success)" 
                    Text="@evento.EstadoCajon2" />
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="EventoSensorDto" Property="CocheraLlena" Title="Lleno" Width="80px">
            <Template Context="evento">
                @if (evento.CocheraLlena)
                {
                    <RadzenIcon Icon="error" Style="color: red;" />
                }
                else
                {
                    <RadzenIcon Icon="check_circle" Style="color: green;" />
                }
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="EventoSensorDto" Property="TimestampESP32" Title="Timestamp ESP32" Width="100px" />
    </Columns>
</RadzenDataGrid>

@code {
    private List<EventoSensorDto> eventos = new();
    private RadzenDataGrid<EventoSensorDto>? grid;
    private DateTime fechaDesde = DateTime.Today;
    private DateTime fechaHasta = DateTime.Today.AddDays(1).AddSeconds(-1);
    private HubConnection? hubConnection;
    private bool conectado;

    protected override async Task OnInitializedAsync()
    {
        await CargarUltimos();
        await SetupSignalR();
    }

    private async Task CargarUltimos()
    {
        eventos = (await EventoService.GetUltimosEventosAsync(50)).ToList();
    }

    private async Task FiltrarEventos()
    {
        eventos = (await EventoService.GetEventosByFechaAsync(fechaDesde, fechaHasta)).ToList();
    }

    private async Task SetupSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/cocherahub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<EventoSensorDto>("RecibirEvento", async (evento) =>
        {
            eventos.Insert(0, evento);
            if (eventos.Count > 100)
                eventos.RemoveAt(eventos.Count - 1);
            await InvokeAsync(StateHasChanged);
        });

        hubConnection.Reconnecting += _ =>
        {
            conectado = false;
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };

        hubConnection.Reconnected += _ =>
        {
            conectado = true;
            InvokeAsync(StateHasChanged);
            return Task.CompletedTask;
        };

        try
        {
            await hubConnection.StartAsync();
            conectado = true;
        }
        catch
        {
            conectado = false;
        }
    }

    private BadgeStyle GetBadgeStyle(Domain.Enums.TipoEvento tipo)
    {
        return tipo switch
        {
            Domain.Enums.TipoEvento.CajonOcupado => BadgeStyle.Warning,
            Domain.Enums.TipoEvento.CajonLiberado => BadgeStyle.Success,
            Domain.Enums.TipoEvento.MovimientoEntrada => BadgeStyle.Info,
            Domain.Enums.TipoEvento.MovimientoEntradaBloqueado => BadgeStyle.Danger,
            Domain.Enums.TipoEvento.CocheraLlena => BadgeStyle.Danger,
            Domain.Enums.TipoEvento.VehiculoSalio => BadgeStyle.Light,
            Domain.Enums.TipoEvento.SistemaIniciado => BadgeStyle.Primary,
            _ => BadgeStyle.Secondary
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
